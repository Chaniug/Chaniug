/**
 * Chaniug Personal Website - Main Stylesheet
 * 由 build.js 自动生成，请勿直接编辑此文件
 * 编辑 css/modules/ 下的模块文件后运行: npm run build:css
 *
 * 生成时间: 2026-06-11T15:36:34.983Z
 */


/* ============================================ */
/* variables.css */
/* ============================================ */

/* ============================================================
   VARIABLES — CSS 自定义属性（设计令牌）
   ============================================================ */

:root {
    /* ---- 颜色体系 ---- */
    --bg-deep: #0a0a14;
    --text-primary: rgba(255, 255, 255, 0.92);
    --text-secondary: rgba(255, 255, 255, 0.55);
    --text-muted: rgba(255, 255, 255, 0.35);
    
    /* ---- 玻璃拟态 ---- */
    --glass-bg: rgba(255, 255, 255, 0.04);
    --glass-border: rgba(255, 255, 255, 0.08);
    --glass-hover: rgba(255, 255, 255, 0.07);
    
    /* ---- 强调色 ---- */
    --accent-blue: #4f8cff;
    --accent-purple: #a855f7;
    --accent-cyan: #22d3ee;
    
    /* ---- 过渡动画 ---- */
    --transition-fast: 0.2s ease;
    --transition-smooth: 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    
    /* ---- 字体 ---- */
    --font-sans: "Inter", "SF Pro Display", "PingFang SC", "Microsoft YaHei", "Noto Sans SC", -apple-system, BlinkMacSystemFont, sans-serif;
    --font-mono: "Fira Code", "SF Mono", "Cascadia Code", "JetBrains Mono", "Consolas", monospace;
    
    /* ---- 统一间距体系（基于 4px 网格） ---- */
    --space-xs: 0.5rem;   /*  8px — 紧密元素间距 */
    --space-sm: 0.75rem;  /* 12px — 标签/按钮内边距 */
    --space-md: 1rem;     /* 16px — 卡片内边距 / 社交链接间距 */
    --space-lg: 1.5rem;   /* 24px — 网格 gap / 区块内间距 */
    --space-xl: 2rem;     /* 32px — 大区块间距 */
    --space-2xl: 2.5rem;  /* 40px — section-label 到内容 */
    --space-3xl: 3rem;    /* 48px — section 内部 gap */
}


/* ============================================ */
/* reset.css */
/* ============================================ */

/* ============================================================
   RESET MODULE
   Auto-generated by split-css.js
   ============================================================ */

/* ============================================================
   RESET & BASE
   ============================================================ */
*, *::before, *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

:root {
    --bg-deep: #0a0a14;
    --text-primary: rgba(255, 255, 255, 0.92);
    --text-secondary: rgba(255, 255, 255, 0.55);
    --text-muted: rgba(255, 255, 255, 0.35);
    --glass-bg: rgba(255, 255, 255, 0.04);
    --glass-border: rgba(255, 255, 255, 0.08);
    --glass-hover: rgba(255, 255, 255, 0.07);
    --accent-blue: #4f8cff;
    --accent-purple: #a855f7;
    --accent-cyan: #22d3ee;
    --transition-fast: 0.2s ease;
    --transition-smooth: 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    /* 字体变量 */
    --font-sans: "Inter", "SF Pro Display", "PingFang SC", "Microsoft YaHei", "Noto Sans SC", -apple-system, BlinkMacSystemFont, sans-serif;
    --font-mono: "Fira Code", "SF Mono", "Cascadia Code", "JetBrains Mono", "Consolas", monospace;
    /* ===== 统一间距体系（基于 4px 网格） ===== */
    --space-xs: 0.5rem;   /*  8px — 紧密元素间距 */
    --space-sm: 0.75rem;  /* 12px — 标签/按钮内边距 */
    --space-md: 1rem;     /* 16px — 卡片内边距 / 社交链接间距 */
    --space-lg: 1.5rem;   /* 24px — 网格 gap / 区块内间距 */
    --space-xl: 2rem;     /* 32px — 大区块间距 */
    --space-2xl: 2.5rem;  /* 40px — section-label 到内容 */
    --space-3xl: 3rem;    /* 48px — section 内部 gap */
}

html {
    scroll-behavior: smooth;
    font-size: 16px;
}

body {
    font-family: var(--font-sans);
    background: var(--bg-deep);
    color: var(--text-primary);
    min-height: 100vh;
    overflow-x: hidden;
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
}

a {
    color: inherit;
    text-decoration: none;
}

img {
    max-width: 100%;
    display: block;
}


/* ============================================ */
/* layout.css */
/* ============================================ */

/* ============================================================
   LAYOUT MODULE
   Auto-generated by split-css.js
   ============================================================ */

   PREFERS REDUCED MOTION — 尊重系统动画减弱偏好
   ============================================================ */
@media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
        scroll-behavior: auto !important;
    }
    #starfield, #nebula, #starDust, .constellation-canvas {
        display: none !important;
    }
}

/* ============================================================
   CANVAS STARFIELD
   ============================================================ */
#starfield {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    mix-blend-mode: screen;
}



/* ============================================================
   CANVAS STAR DUST — 微尘粒子（底部缓慢升起）
   ============================================================ */
#starDust {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    mix-blend-mode: screen;
}
#nebula {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    mix-blend-mode: screen;
}

/* ============================================================
   NOISE OVERLAY — 全局胶片噪点纹理
   ============================================================ */
.noise-overlay {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0.028;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n' x='0' y='0'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 200px 200px;
    /* Firefox 回退：使用伪噪点（无 backdrop-filter 依赖） */
}
@supports not (backdrop-filter: blur(1px)) {
    .noise-overlay {
        opacity: 0.04;
        background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
        background-size: 60px 60px;
    }
}

/* ============================================================
   GRID OVERLAY — 全局科技网格线（增强版：双密度网格）
   ============================================================ */
.grid-overlay {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0.07;
    /* 粗网格（60px）+ 细网格（20px）叠加，形成层次感 */
    background-image:
        /* 粗网格：水平线 */
        linear-gradient(rgba(79, 140, 255, 0.25) 1px, transparent 1px),
        /* 粗网格：垂直线 */
        linear-gradient(90deg, rgba(79, 140, 255, 0.25) 1px, transparent 1px),
        /* 细网格：水平线 */
        linear-gradient(rgba(34, 211, 238, 0.12) 0.5px, transparent 0.5px),
        /* 细网格：垂直线 */
        linear-gradient(90deg, rgba(34, 211, 238, 0.12) 0.5px, transparent 0.5px);
    background-size:
        60px 60px,
        60px 60px,
        20px 20px,
        20px 20px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 40%, black 20%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 40%, black 20%, transparent 70%);
}

/* ============================================================
   SCANLINE OVERLAY — 对角线光扫描（动态）
   ============================================================ */
.scanline-overlay {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0.04;
    background: repeating-linear-gradient(
        -45deg,
        transparent,
        transparent 2px,
        rgba(79, 140, 255, 0.2) 2px,
        rgba(79, 140, 255, 0.2) 2.5px
    );
    animation: scanline-drift 20s linear infinite;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 10%, transparent 60%);
    -webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 10%, transparent 60%);
}

@keyframes scanline-drift {
    0% { transform: translateX(0); }
    100% { transform: translateX(20px); }
}

/* ============================================================
   HEX MESH OVERLAY — 蜂窝微纹理（科技感）
   ============================================================ */
.hex-mesh-overlay {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0.05;
    /* 纯 CSS 蜂窝图案：用三层交错线条模拟六边形 */
    background-image:
        /* 水平线 */
        linear-gradient(rgba(168, 85, 247, 0.3) 0.5px, transparent 0.5px),
        /* 60° 斜线 */
        linear-gradient(60deg, rgba(79, 140, 255, 0.2) 0.5px, transparent 0.5px),
        /* -60° 斜线 */
        linear-gradient(-60deg, rgba(34, 211, 238, 0.2) 0.5px, transparent 0.5px);
    background-size:
        30px 30px,
        30px 30px,
        30px 30px;
    mask-image: radial-gradient(ellipse 90% 90% at 50% 50%, black 5%, transparent 60%);
    -webkit-mask-image: radial-gradient(ellipse 90% 90% at 50% 50%, black 5%, transparent 60%);
}

/* ============================================================
   FLOATING ORBS (光球) — 宇宙能量球
   ============================================================ */
.orb {
    position: fixed;
    border-radius: 50%;
    filter: blur(60px);
    opacity: 0.10;
    z-index: 0;
    pointer-events: none;
    will-change: transform;
}

/* 移动端禁用光球，避免 GPU 过度消耗导致发烫 */
@media (max-width: 768px) {
    .orb {
        display: none;
    }
}

.orb-1 {
    width: 700px;
    height: 700px;
    background: radial-gradient(circle at 40% 40%, #4f8cff 0%, #2563eb 30%, transparent 70%);
    top: -250px;
    left: -150px;
    animation: float-orb-1 20s ease-in-out infinite;
}

.orb-2 {
    width: 550px;
    height: 550px;
    background: radial-gradient(circle at 60% 50%, #a855f7 0%, #7c3aed 30%, transparent 70%);
    top: 40%;
    right: -200px;
    opacity: 0.12;
    animation: float-orb-2 25s ease-in-out infinite;
}

.orb-3 {
    width: 500px;
    height: 500px;
    background: radial-gradient(circle at 50% 50%, #22d3ee 0%, #06b6d4 25%, transparent 70%);
    bottom: -150px;
    left: 25%;
    opacity: 0.09;
    animation: float-orb-3 22s ease-in-out infinite;
}

.orb-4 {
    width: 600px;
    height: 600px;
    background: radial-gradient(circle at 30% 60%, #c084fc 0%, #a855f7 25%, #4f8cff 50%, transparent 75%);
    top: 30%;
    left: 50%;
    opacity: 0.06;
    animation: float-orb-4 18s ease-in-out infinite;
}

@keyframes float-orb-1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    25% { transform: translate(80px, 60px) scale(1.1); }
    50% { transform: translate(40px, -30px) scale(0.95); }
    75% { transform: translate(-30px, 20px) scale(1.05); }
}

@keyframes float-orb-2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(-60px, -80px) scale(1.08); }
    66% { transform: translate(30px, -40px) scale(0.92); }
}

@keyframes float-orb-3 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    25% { transform: translate(-50px, -40px) scale(1.05); }
    50% { transform: translate(60px, -20px) scale(0.95); }
    75% { transform: translate(20px, 30px) scale(1.08); }
}

@keyframes float-orb-4 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(70px, -50px) scale(1.12); }
    66% { transform: translate(-40px, 30px) scale(0.9); }
}

/* ============================================================
   SPOTLIGHT (鼠标聚光灯)
   ============================================================ */
#spotlight {
    position: fixed;
    top: 0;
    left: 0;
    width: 800px;
    height: 800px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.06) 0%, transparent 70%);
    pointer-events: none;
    z-index: 1;
    transform: translate(-50%, -50%);
    transition: transform 0.15s ease-out;
    will-change: transform;
}

/* ============================================================
   SECTION LAYOUT — 精确节奏
   ============================================================ */
.section {
    position: relative;
    z-index: 2;
    padding: 7rem var(--space-lg) 5.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    min-height: auto;
    justify-content: center;
    gap: 3.5rem;
}

.section-inner {
    width: 100%;
    max-width: 960px;
    margin: 0 auto;
}

/* 区块分隔光晕线 */
.section + .section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 10%;
    right: 10%;
    height: 1px;
    background: linear-gradient(
        to right,
        transparent,
        rgba(79, 140, 255, 0.12) 15%,
        rgba(168, 85, 247, 0.2) 40%,
        rgba(34, 211, 238, 0.15) 60%,
        rgba(79, 140, 255, 0.12) 85%,
        transparent
    );
    pointer-events: none;
}

/* 区块分隔菱形装饰点 */
.section + .section::after {
    content: '';
    position: absolute;
    top: -4.5px;
    left: 50%;
    transform: translateX(-50%) rotate(45deg);
    width: 8px;
    height: 8px;
    background: rgba(168, 85, 247, 0.25);
    border: 1px solid rgba(168, 85, 247, 0.3);
    pointer-events: none;
}

/* ============================================================
   MARQUEE — 装饰滚动字幕条（页面分隔装饰）
   ============================================================ */
.marquee-section {
    width: 100%;
    overflow: hidden;
    padding: 1.2rem 0;
    margin: 0.5rem 0 1rem;
    position: relative;
    z-index: 3;
    /* 顶部细线分隔 */
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    /* 移除背景或减弱背景，使其更融入页面 */
    background: transparent;
    /* 左右渐变淡出遮罩 */
    mask-image: linear-gradient(
        to right,
        transparent 0%,
        black 15%,
        black 85%,
        transparent 100%
    );
    -webkit-mask-image: linear-gradient(
        to right,
        transparent 0%,
        black 15%,
        black 85%,
        transparent 100%
    );
}

.marquee-track {
    display: flex;
    gap: 2rem;
    width: fit-content;
    animation: marqueeScroll 40s linear infinite;
}

.marquee-track:hover {
    animation-play-state: paused;
}

.marquee-content {
    display: flex;
    align-items: center;
    gap: 1rem;
    white-space: nowrap;
    flex-shrink: 0;
}

/* 文字：小号渐变镂空 */
.marquee-content span {
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    cursor: default;
    background: linear-gradient(
        135deg,
        rgba(255, 255, 255, 0.45) 0%,
        rgba(255, 255, 255, 0.7) 40%,
        rgba(255, 255, 255, 0.45) 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    transition: all 0.35s ease;
}

.marquee-content span:hover {
    background: linear-gradient(
        135deg,
        #4f8cff 0%,
        #a855f7 50%,
        #22d3ee 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    filter: drop-shadow(0 0 6px rgba(79, 140, 255, 0.4));
}

.marquee-dot {
    font-size: 0.65rem;
    font-weight: 400;
    user-select: none;
    -webkit-user-select: none;
    color: rgba(255, 255, 255, 0.15);
}

@keyframes marqueeScroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
}

/* ===== 极简标签式标题 ===== */
.section-label {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
    margin-bottom: var(--space-2xl);
    opacity: 0.55;
}

.section-label .label-line {
    display: block;
    width: clamp(28px, 7vw, 56px);
    height: 1px;
    background: linear-gradient(
        to right,
        transparent,
        rgba(255, 255, 255, 0.3),
        transparent
    );
}

.section-label .label-text {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.32em;
    color: var(--text-secondary);
    text-transform: uppercase;
    white-space: nowrap;
}

/* ============================================================
   GLASS CARD — 宇宙玻璃拟态
   ============================================================ */
.glass-card {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 20px;
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
}
/* Firefox 回退：无法使用 backdrop-filter 时加深背景 */
@supports not (backdrop-filter: blur(1px)) {
    .glass-card {
        background: rgba(15, 15, 30, 0.55);
    }
}

/* 移动端禁用 backdrop-filter，改用纯色半透明背景
   避免滚动时 GPU 重新计算模糊导致闪烁和发热 */
@media (max-width: 768px) {
    .glass-card,
    .hero-bio,
    .social-link,
    .constellation-node,
    .site-nav,
    .site-nav.scrolled,
    .nav-links {
        backdrop-filter: none;
        -webkit-backdrop-filter: none;
    }

    /* 伪元素也需要禁用 */
    .hero-slide-image.image-float .gallery-image-wrapper::after {
        backdrop-filter: none;
        -webkit-backdrop-filter: none;
    }

    .glass-card {
        background: rgba(10, 10, 26, 0.85);
    }

    .site-nav,
    .site-nav.scrolled {
        background: rgba(10, 10, 20, 0.95);
    }

    .constellation-node {
        background: rgba(10, 10, 20, 0.9);
    }

    .hero-bio {
        background: rgba(10, 10, 26, 0.8);
    }

    .social-link {
        background: rgba(255, 255, 255, 0.06);
    }

    .nav-links {
        background: rgba(10, 10, 20, 0.98);
    }

    /* 技能标签芯片也禁用 backdrop-filter */
    .hero-bio span[class*="tag"] {
        backdrop-filter: none;
        -webkit-backdrop-filter: none;
        background: rgba(255, 255, 255, 0.06);
    }
}

/* 卡片悬停光晕 */
.glass-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(
        600px circle at var(--mouse-x, 50%) var(--mouse-y, 50%),
        rgba(79, 140, 255, 0.06),
        transparent 50%
    );
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
    z-index: 0;
}

.glass-card:hover::before {
    opacity: 1;
}

.glass-card > * {
    position: relative;
    z-index: 1;
}

.glass-card:hover {
    background: var(--glass-hover);
    border-color: rgba(255, 255, 255, 0.15);
    transform: translateY(-4px);
    box-shadow:
        0 8px 32px rgba(0, 0, 0, 0.4),
        0 0 0 1px rgba(79, 140, 255, 0.12) inset;
}

/* ============================================================
   FOOTER
   ============================================================ */
.site-footer {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 4rem 1.5rem 4rem;
    color: var(--text-muted);
    font-size: 0.78rem;
    letter-spacing: 0.05em;
    font-weight: 400;
}

/* 页脚哲思寄语 */
.footer-motto {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
    opacity: 0.6;
    transition: opacity 0.5s ease, color 0.5s ease;
}
.footer-motto:hover {
    opacity: 1;
    color: var(--accent-cyan);
}

/* 装饰分割线 */
.footer-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    margin-bottom: 1.6rem;
    position: relative;
}

.footer-divider-line {
    height: 1px;
    width: 120px;
    background: linear-gradient(
        to right,
        transparent,
        rgba(79, 140, 255, 0.2),
        rgba(168, 85, 247, 0.25),
        rgba(79, 140, 255, 0.2),
        transparent
    );
}

.footer-divider-dot {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent-blue);
    box-shadow: 0 0 10px rgba(79, 140, 255, 0.6), 0 0 24px rgba(79, 140, 255, 0.25);
    animation: footer-dot-pulse 2.5s ease-in-out infinite;
}

@keyframes footer-dot-pulse {
    0%, 100% {
        transform: translate(-50%, -50%) scale(1);
        opacity: 0.7;
        box-shadow: 0 0 10px rgba(79, 140, 255, 0.6), 0 0 24px rgba(79, 140, 255, 0.25);
    }
    50% {
        transform: translate(-50%, -50%) scale(1.6);
        opacity: 1;
        box-shadow: 0 0 18px rgba(79, 140, 255, 0.8), 0 0 40px rgba(168, 85, 247, 0.35);
    }
}


/* ============================================ */
/* navigation.css */
/* ============================================ */

/* ============================================================
   NAVIGATION MODULE
   Auto-generated by split-css.js
   ============================================================ */

/* ============================================================
   SITE NAVIGATION — 顶部固定导航条
   ============================================================ */
.site-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    height: 60px;
    background: rgba(10, 10, 20, 0.12);
    backdrop-filter: blur(8px) saturate(140%);
    -webkit-backdrop-filter: blur(8px) saturate(140%);
    border-bottom: 1px solid rgba(255, 255, 255, 0.03);
    transition: background 0.5s ease, border-color 0.5s ease, box-shadow 0.5s ease, backdrop-filter 0.5s ease;
}

/* 滚动后加深 */
.site-nav.scrolled {
    background: rgba(10, 10, 20, 0.55);
    backdrop-filter: blur(18px) saturate(180%);
    -webkit-backdrop-filter: blur(18px) saturate(180%);
    border-bottom-color: rgba(255, 255, 255, 0.08);
    box-shadow: 0 4px 32px rgba(0, 0, 0, 0.5);
}

.nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 var(--space-lg);
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
}

/* ---- Logo ---- */
.nav-logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--text-primary);
    font-weight: 700;
    font-size: 1.05rem;
    letter-spacing: 0.02em;
    z-index: 1001;
    transition: opacity 0.3s ease;
}
.nav-logo:hover {
    opacity: 0.85;
}
.nav-logo svg {
    width: 28px;
    height: 28px;
    flex-shrink: 0;
}

/* ---- 导航链接列表 ---- */
.nav-links {
    list-style: none;
    display: flex;
    gap: 0.25rem;
}

.nav-link {
    display: block;
    padding: 0.45rem 1rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    border-radius: 8px;
    letter-spacing: 0.02em;
    transition: color 0.3s ease, background 0.3s ease;
    position: relative;
}
.nav-link:hover {
    color: var(--text-primary);
    background: rgba(255, 255, 255, 0.06);
}
.nav-link.active {
    color: var(--accent-blue);
}

/* ---- 下划线指示器 ---- */
.nav-indicator {
    position: absolute;
    bottom: 0;
    left: 0;
    height: 2.5px;
    background: linear-gradient(90deg, var(--accent-blue), var(--accent-purple));
    border-radius: 2px 2px 0 0;
    transition: left 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
                width 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
                opacity 0.3s ease;
    opacity: 0;
    pointer-events: none;
}
.nav-indicator.visible {
    opacity: 1;
}

/* ---- 移动端汉堡菜单按钮 ---- */
.nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    padding: 0;
    background: none;
    border: none;
    cursor: pointer;
    z-index: 1001;
    border-radius: 8px;
    transition: background 0.3s ease;
}
.nav-toggle:hover {
    background: rgba(255, 255, 255, 0.06);
}
.nav-toggle-bar {
    display: block;
    width: 22px;
    height: 2px;
    border-radius: 2px;
    background: var(--text-primary);
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1),
                opacity 0.25s ease;
    transform-origin: center;
}

/* 激活态：变 × */
.nav-toggle.active .nav-toggle-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
}
.nav-toggle.active .nav-toggle-bar:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
}
.nav-toggle.active .nav-toggle-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
}


/* ============================================ */
/* hero.css */
/* ============================================ */

/* ============================================================
   HERO MODULE
   Auto-generated by split-css.js
   ============================================================ */

/* ============================================================
   HERO ORBITS — 科技轨道装饰环
   ============================================================ */
.hero-orbits {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 420px;
    height: 420px;
    pointer-events: none;
    z-index: 0;
}

.orbit-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1px solid;
}

.orbit-ring.ring-1 {
    border-color: rgba(79, 140, 255, 0.12);
    animation: orbitSpin 28s linear infinite;
}

.orbit-ring.ring-2 {
    inset: 30px;
    border-color: rgba(168, 85, 247, 0.1);
    animation: orbitSpin 22s linear infinite reverse;
}

.orbit-ring.ring-3 {
    inset: 60px;
    border-color: rgba(34, 211, 238, 0.09);
    animation: orbitSpin 18s linear infinite;
}

/* 轨道环上的光点 */
.orbit-ring::before {
    content: '';
    position: absolute;
    top: -3px;
    left: 50%;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    transform: translateX(-50%);
}

.ring-1::before { background: var(--accent-blue);   box-shadow: 0 0 12px var(--accent-blue), 0 0 24px rgba(79, 140, 255, 0.4); }
.ring-2::before { background: var(--accent-purple); box-shadow: 0 0 12px var(--accent-purple), 0 0 24px rgba(168, 85, 247, 0.4); }
.ring-3::before { background: var(--accent-cyan);   box-shadow: 0 0 10px var(--accent-cyan), 0 0 20px rgba(34, 211, 238, 0.35); }

@keyframes orbitSpin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
}

/* ============================================================
   HERO
   ============================================================ */
#hero {
    min-height: 100vh;
    padding-top: 4rem;
    overflow: hidden;
    position: relative;
}

/* C1: 背景微动效 — 极慢径向渐变漂移，性能消耗极低 */
#hero::before {
    content: '';
    position: absolute;
    inset: -20%;
    width: 140%;
    height: 140%;
    background:
        radial-gradient(ellipse 30% 40% at 20% 50%, rgba(79, 140, 255, 0.04) 0%, transparent 70%),
        radial-gradient(ellipse 25% 35% at 80% 30%, rgba(168, 85, 247, 0.03) 0%, transparent 65%),
        radial-gradient(ellipse 20% 30% at 50% 80%, rgba(34, 211, 238, 0.03) 0%, transparent 60%);
    background-size: 200% 200%;
    animation: hero-bg-drift 60s ease-in-out infinite alternate;
    pointer-events: none;
    z-index: 0;
    will-change: background-position;
}

@keyframes hero-bg-drift {
    0%   { background-position: 0% 0%; }
    100% { background-position: 100% 100%; }
}

.hero-content {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    z-index: 2;
}

/* ===== 头像容器 ===== */
.avatar-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.375rem;
}

/* 头像 */
.avatar {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    overflow: visible;
    border: 2px solid rgba(255, 255, 255, 0.15);
    box-shadow:
        0 0 40px rgba(79, 140, 255, 0.25),
        0 0 80px rgba(168, 85, 247, 0.15),
        0 0 120px rgba(79, 140, 255, 0.06);
    transition: transform var(--transition-smooth), box-shadow var(--transition-smooth);
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--accent-blue), var(--accent-purple));
    font-size: 3rem;
    color: white;
    font-weight: 700;
    cursor: default;
    position: relative;
}

/* 头像光环 */
.avatar::before {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    background: linear-gradient(135deg, #4f8cff, #a855f7, #22d3ee, #4f8cff);
    background-size: 400% 400%;
    z-index: -1;
    animation: avatarGlow 4s ease infinite;
    opacity: 0.4;
    filter: blur(8px);
}

/* 头像轨道环 */
.avatar::after {
    content: '';
    position: absolute;
    inset: -10px;
    border-radius: 50%;
    border: 1.5px solid rgba(79, 140, 255, 0.2);
    z-index: -2;
    animation: orbitPulse 3s ease-in-out infinite;
}

@keyframes orbitPulse {
    0%, 100% {
        inset: -10px;
        border-color: rgba(79, 140, 255, 0.15);
        opacity: 0.5;
    }
    50% {
        inset: -14px;
        border-color: rgba(168, 85, 247, 0.35);
        opacity: 0.9;
    }
}

@keyframes avatarGlow {
    0%   { background-position: 0% 50%; }
    50%  { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
}

/* 在线状态指示点 */
.avatar-status {
    position: absolute;
    bottom: 4px;
    right: 4px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: #22c55e;
    border: 2.5px solid var(--bg-deep);
    box-shadow:
        0 0 8px rgba(34, 197, 94, 0.5),
        0 0 16px rgba(34, 197, 94, 0.2);
    z-index: 3;
    animation: statusPulse 2s ease-in-out infinite;
}

@keyframes statusPulse {
    0%, 100% { box-shadow: 0 0 8px rgba(34, 197, 94, 0.5), 0 0 16px rgba(34, 197, 94, 0.2); }
    50%      { box-shadow: 0 0 14px rgba(34, 197, 94, 0.7), 0 0 24px rgba(34, 197, 94, 0.35); }
}

.avatar:hover {
    transform: scale(1.08);
    box-shadow:
        0 0 60px rgba(79, 140, 255, 0.45),
        0 0 100px rgba(168, 85, 247, 0.3),
        0 0 140px rgba(79, 140, 255, 0.1);
}

.avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    position: relative;
    z-index: 2;
}

/* 名字 */
.hero-name {
    font-family: var(--font-sans);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 0.5rem;
    background: linear-gradient(135deg, #fff 0%, var(--accent-blue) 50%, var(--accent-purple) 100%);
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: shimmer 3s linear infinite;
}

@keyframes shimmer {
    to { background-position: 200% center; }
}

/* 标语 — 位于 bio 卡片内，作为开场声明 */
.hero-tagline {
    font-size: 1.1rem;
    color: var(--text-primary);
    font-weight: 600;
    letter-spacing: 0.03em;
    line-height: 1.6;
    text-align: center;
    margin: 0;
    position: relative;
    z-index: 1;
}

/* Bio — 技能标签芯片 + 描述 */
.hero-bio {
    max-width: 560px;
    padding: var(--space-md) var(--space-lg);
    border-radius: 14px;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    transition: box-shadow 0.5s ease, background 0.4s ease, border-color 0.4s ease;
}

/* 顶部微光渐变条 — 与 ABOUT 卡片呼应 */
.hero-bio::after {
    content: '';
    position: absolute;
    top: 0;
    left: 15%;
    right: 15%;
    height: 1.5px;
    background: linear-gradient(90deg,
        transparent 0%,
        var(--accent-blue) 20%,
        var(--accent-purple) 50%,
        var(--accent-cyan) 80%,
        transparent 100%
    );
    border-radius: 0 0 2px 2px;
    opacity: 0;
    transition: opacity 0.5s ease, left 0.5s ease, right 0.5s ease;
    z-index: 2;
}

/* hover 时内部光扫描掠过 */
.hero-bio::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(
        ellipse 60% 30% at 50% 50%,
        rgba(79, 140, 255, 0.06) 0%,
        transparent 70%
    );
    opacity: 0;
    transition: opacity 0.6s ease;
    pointer-events: none;
    z-index: 0;
    animation: bio-scan 4s ease-in-out infinite;
}

@keyframes bio-scan {
    0%, 100% { transform: translateY(-10%); }
    50% { transform: translateY(10%); }
}

.hero-bio:hover {
    background: var(--glass-hover);
    border-color: rgba(255, 255, 255, 0.15);
    box-shadow:
        0 8px 32px rgba(0, 0, 0, 0.4),
        0 0 0 1px rgba(79, 140, 255, 0.08) inset,
        0 0 60px rgba(79, 140, 255, 0.05);
}

.hero-bio:hover::after {
    opacity: 1;
    left: 5%;
    right: 5%;
}

.hero-bio:hover::before {
    opacity: 1;
}

/* ---- 技能芯片行 ---- */
.hero-skill-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    position: relative;
    z-index: 1;
}

.skill-chip-tag {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    padding: 0.3rem 0.75rem;
    border-radius: 8px;
    color: rgba(255, 255, 255, 0.85);
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
                background 0.3s ease,
                border-color 0.3s ease,
                box-shadow 0.3s ease,
                color 0.3s ease;
    cursor: default;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    opacity: 0;
    animation: chipEnter 0.5s ease forwards;
}

/* 彩色圆点前缀 — 呼吸脉动 + hover 放大 */
.skill-chip-tag::before {
    content: '';
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    animation: dotBreathe 2.8s ease-in-out infinite;
}

.skill-chip-tag:hover::before {
    transform: scale(1.3);
    animation: none;
}

/* 每个芯片独立配色 + 渐进入场 + 呼吸错开 */
.skill-chip-tag:nth-child(1) {
    border-color: rgba(79, 140, 255, 0.35);
    background: rgba(79, 140, 255, 0.08);
    color: #8bb4ff;
    animation-delay: 0.55s;
}
.skill-chip-tag:nth-child(1)::before {
    background: var(--accent-blue);
    box-shadow: 0 0 6px rgba(79, 140, 255, 0.5);
    animation-delay: 1.05s;
}
.skill-chip-tag:nth-child(2) {
    border-color: rgba(168, 85, 247, 0.35);
    background: rgba(168, 85, 247, 0.08);
    color: #c79dff;
    animation-delay: 0.68s;
}
.skill-chip-tag:nth-child(2)::before {
    background: var(--accent-purple);
    box-shadow: 0 0 6px rgba(168, 85, 247, 0.5);
    animation-delay: 1.4s;
}
.skill-chip-tag:nth-child(3) {
    border-color: rgba(34, 211, 238, 0.35);
    background: rgba(34, 211, 238, 0.08);
    color: #5be0f5;
    animation-delay: 0.81s;
}
.skill-chip-tag:nth-child(3)::before {
    background: var(--accent-cyan);
    box-shadow: 0 0 6px rgba(34, 211, 238, 0.5);
    animation-delay: 1.75s;
}
.skill-chip-tag:nth-child(4) {
    border-color: rgba(192, 132, 252, 0.35);
    background: rgba(192, 132, 252, 0.08);
    color: #d9b8ff;
    animation-delay: 0.94s;
}
.skill-chip-tag:nth-child(4)::before {
    background: #c084fc;
    box-shadow: 0 0 6px rgba(192, 132, 252, 0.5);
    animation-delay: 2.1s;
}

.skill-chip-tag:hover {
    transform: translateY(-3px) scale(1.06);
}

.skill-chip-tag:nth-child(1):hover {
    background: rgba(79, 140, 255, 0.18);
    border-color: rgba(79, 140, 255, 0.6);
    box-shadow: 0 4px 16px rgba(79, 140, 255, 0.25);
    color: #fff;
}
.skill-chip-tag:nth-child(1):hover::before {
    box-shadow: 0 0 12px rgba(79, 140, 255, 0.7);
}
.skill-chip-tag:nth-child(2):hover {
    background: rgba(168, 85, 247, 0.18);
    border-color: rgba(168, 85, 247, 0.6);
    box-shadow: 0 4px 16px rgba(168, 85, 247, 0.25);
    color: #fff;
}
.skill-chip-tag:nth-child(2):hover::before {
    box-shadow: 0 0 12px rgba(168, 85, 247, 0.7);
}
.skill-chip-tag:nth-child(3):hover {
    background: rgba(34, 211, 238, 0.18);
    border-color: rgba(34, 211, 238, 0.6);
    box-shadow: 0 4px 16px rgba(34, 211, 238, 0.25);
    color: #fff;
}
.skill-chip-tag:nth-child(3):hover::before {
    box-shadow: 0 0 12px rgba(34, 211, 238, 0.7);
}
.skill-chip-tag:nth-child(4):hover {
    background: rgba(192, 132, 252, 0.18);
    border-color: rgba(192, 132, 252, 0.6);
    box-shadow: 0 4px 16px rgba(192, 132, 252, 0.25);
    color: #fff;
}
.skill-chip-tag:nth-child(4):hover::before {
    box-shadow: 0 0 12px rgba(192, 132, 252, 0.7);
}

/* 芯片动效关键帧 */
@keyframes chipEnter {
    from { opacity: 0; transform: translateY(10px) scale(0.92); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
}
@keyframes dotBreathe {
    0%, 100% { transform: scale(1); }
    50%      { transform: scale(1.5); }
}

/* ---- 描述文字 ---- */
.hero-desc {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.7;
    letter-spacing: 0.02em;
    margin: var(--space-xs) 0 0;
    position: relative;
    z-index: 1;
}

/* 打字机光标 */
.typing-cursor {
    display: inline-block;
    color: var(--accent-cyan);
    font-weight: 300;
    animation: cursor-blink 1s step-end infinite;
    margin-left: 2px;
}

@keyframes cursor-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
}

/* 社交链接 */
.social-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-md);
    justify-content: center;
}

.social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.55rem 1.3rem;
    border-radius: 9999px;
    font-size: 0.88rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    transition: all var(--transition-fast);
}

.social-link:hover {
    background: var(--glass-hover);
    border-color: rgba(255, 255, 255, 0.2);
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
}

/* 社交链接 SVG 图标 */
.sl-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    opacity: 0.7;
    transition: opacity 0.3s ease;
}

.social-link:hover .sl-icon {
    opacity: 1;
}

/* ===== Hero 滚动引导提示 ===== */
.scroll-hint {
    position: absolute;
    bottom: 1.8rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    z-index: 5;
    opacity: 0.45;
    transition: opacity 0.4s ease;
    text-decoration: none;
    animation: hintReveal 0.8s ease 1.6s both;
    cursor: pointer;
}

.scroll-hint:hover {
    opacity: 0.85;
}

.scroll-hint-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-muted);
}

.scroll-hint-chevron {
    display: block;
    width: 10px;
    height: 10px;
    border-right: 1.5px solid var(--accent-cyan);
    border-bottom: 1.5px solid var(--accent-cyan);
    transform: rotate(45deg);
    animation: chevronBounce 2.2s ease-in-out infinite;
}

@keyframes hintReveal {
    from { opacity: 0; transform: translateX(-50%) translateY(12px); }
    to   { opacity: 0.45; transform: translateX(-50%) translateY(0); }
}

@keyframes chevronBounce {
    0%, 100% { transform: rotate(45deg) translateY(0); opacity: 0.5; }
    55%      { transform: rotate(45deg) translateY(-7px); opacity: 1; }
    75%      { opacity: 0.5; }
}

/* ============================================================
   HERO SLIDESHOW — 全宽文字+图片整体轮播
   ============================================================ */
.hero-slideshow {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: 10px;
}

.hero-slideshow-track {
    display: flex;
    height: 100%;
    transition: transform 0.9s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform;
}

.hero-slide {
    flex: 0 0 100%;
    display: flex;
    align-items: stretch;
    gap: var(--space-md);
    min-height: 320px;
}

/* 左侧文字区域 */
.hero-slide-text {
    flex: 1 1 55%;
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 0.2rem 0;
    opacity: 0;
    transform: translateY(18px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.15s,
                transform 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.15s;
}

.hero-slide.slide-active .hero-slide-text {
    opacity: 1;
    transform: translateY(0);
}

/* 右侧图片区域 */
.hero-slide-image {
    flex: 1 1 45%;
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    opacity: 0;
    transform: translateX(24px);
    transition: opacity 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.25s,
                transform 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.25s;
}

.hero-slide.slide-active .hero-slide-image {
    opacity: 1;
    transform: translateX(0);
}

/* Slide 1 图片：文字逐行展开完毕后延迟出现 */
/* 用 :not(.image-visible) 保持隐藏，直到 JS 添加 image-visible */
.hero-slide.slide-active .hero-slide-image.image-reveal:not(.image-visible) {
    opacity: 0;
    transform: translateX(16px);
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
}

.hero-slide.slide-active .hero-slide-image.image-reveal.image-visible {
    opacity: 1;
    transform: translateX(0);
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
}

.hero-slide-image .gallery-image-wrapper {
    width: 100%;
    height: 100%;
    border-radius: 10px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.02);
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255, 255, 255, 0.06);
}

.hero-slide-image .gallery-image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
}

/* ---- Slide 1 Avatar：透明雾气 ---- */
.hero-slide-image.image-reveal .gallery-image-wrapper {
    position: relative;
    border-radius: 50%;
    /* overflow: hidden 配合 border-radius: 50% 最可靠地裁剪 img 为圆形 */
    overflow: visible;
    background: transparent;
    border: none;
    /* box-shadow 不受 overflow:hidden 裁剪，可向外扩散做雾光 */
    box-shadow:
        0 0 25px 12px rgba(160, 190, 255, 0.11),
        0 0 55px 24px rgba(140, 180, 240, 0.06);
    transition: box-shadow 0.5s ease;
    animation: avatar-breathe 3.8s ease-in-out infinite;
    cursor: pointer;
}

@keyframes avatar-breathe {
    0%, 100% {
        box-shadow:
            0 0 25px 12px rgba(160, 190, 255, 0.08),
            0 0 55px 24px rgba(140, 180, 240, 0.04);
    }
    50% {
        box-shadow:
            0 0 35px 18px rgba(160, 190, 255, 0.16),
            0 0 70px 32px rgba(140, 180, 240, 0.1);
    }
}

/* 外围色环暗示 —— 缓慢旋转，暗示图片内藏着彩色 */
.hero-slide-image.image-reveal .gallery-image-wrapper::before {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    z-index: 0;
    background: conic-gradient(
        from 0deg,
        transparent 0deg,
        rgba(100, 160, 255, 0.18) 25deg,
        rgba(160, 130, 240, 0.22) 50deg,
        rgba(100, 200, 220, 0.2) 75deg,
        rgba(255, 180, 140, 0.15) 100deg,
        rgba(180, 220, 160, 0.18) 130deg,
        rgba(140, 180, 255, 0.22) 160deg,
        transparent 200deg,
        transparent 360deg
    );
    animation: hint-ring-rotate 6s linear infinite;
    pointer-events: none;
    opacity: 0.7;
    transition: opacity 0.5s ease;
}

@keyframes hint-ring-rotate {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}

/* hover 时色环淡出（图片本体已变彩色，暗示使命完成） */
.hero-slide-image.image-reveal .gallery-image-wrapper:hover::before {
    opacity: 0;
}

.hero-slide-image.image-reveal .gallery-image-wrapper img {
    position: relative;
    z-index: 2;
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    filter: grayscale(100%);
    transition: filter 0.5s ease, transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    outline: none;
    -webkit-tap-highlight-color: transparent;
    animation: avatar-pulse 4.2s ease-in-out infinite;
}

@keyframes avatar-pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.035); }
}

.hero-slide-image.image-reveal .gallery-image-wrapper:hover {
    box-shadow:
        0 0 40px 18px rgba(160, 190, 255, 0.18),
        0 0 75px 34px rgba(140, 180, 240, 0.1);
}

.hero-slide-image.image-reveal .gallery-image-wrapper:hover img {
    filter: grayscale(0%);
    transform: scale(1.06);
    animation-play-state: paused;
}

/* 定时自动显色 — 延迟后自动从灰度过渡到彩色 */
.hero-slide-image.image-reveal.auto-revealed .gallery-image-wrapper img {
    filter: grayscale(0%);
}

/* ---- Slide 2：毛玻璃透视 —— 由文字水印动画驱动揭示 ---- */
.hero-slide-image.image-float .gallery-image-wrapper {
    position: relative;
    overflow: hidden;
    border-radius: 12px;
    border: none;
    box-shadow: 0 6px 30px -6px rgba(100, 160, 255, 0.06);
    transition: box-shadow 0.8s ease;
}

/* 毛玻璃覆盖层：默认覆盖图片，由 .glass-revealed 控制消退 */
.hero-slide-image.image-float .gallery-image-wrapper::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 3;
    border-radius: 12px;
    background: rgba(12, 15, 25, 0.55);
    backdrop-filter: blur(16px) saturate(0.5);
    -webkit-backdrop-filter: blur(16px) saturate(0.5);
    transition: opacity 0.9s cubic-bezier(0.16, 1, 0.3, 1),
                backdrop-filter 0.9s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
    opacity: 1;
}

/* 渐变微光：毛玻璃表面蓝紫色渐变 */
.hero-slide-image.image-float .gallery-image-wrapper::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 4;
    border-radius: 12px;
    background: linear-gradient(
        135deg,
        rgba(100, 160, 255, 0.14) 0%,
        transparent 40%,
        transparent 60%,
        rgba(168, 130, 255, 0.14) 100%
    );
    pointer-events: none;
    opacity: 1;
    transition: opacity 0.9s cubic-bezier(0.16, 1, 0.3, 1);
}

.hero-slide-image.image-float .gallery-image-wrapper img {
    position: relative;
    z-index: 1;
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 12px;
    transform: scale(1);
    filter: brightness(1);
    transition: transform 0.9s cubic-bezier(0.16, 1, 0.3, 1),
                filter 0.9s ease;
}

/* ---- 揭示态：毛玻璃消退，图片浮现 ---- */
.hero-slide-image.image-float .gallery-image-wrapper.glass-revealed::after {
    opacity: 0;
    backdrop-filter: blur(0px) saturate(1);
    -webkit-backdrop-filter: blur(0px) saturate(1);
}

.hero-slide-image.image-float .gallery-image-wrapper.glass-revealed::before {
    opacity: 0;
}

.hero-slide-image.image-float .gallery-image-wrapper.glass-revealed img {
    transform: scale(1.04);
    filter: brightness(1.1);
}

.hero-slide-image.image-float .gallery-image-wrapper.glass-revealed:hover img {
    transform: scale(1.07);
    filter: brightness(1.16);
}

.hero-slide-image.image-float .gallery-image-wrapper.glass-revealed {
    box-shadow: 0 12px 48px -8px rgba(100, 160, 255, 0.18);
}


/* ============================================================
   HERO SIGNATURE — 动态签名
   ============================================================ */
.hero-signature {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    max-width: min(80vw, 480px);
    margin: 0 auto 0.5rem;
    pointer-events: none;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
}

.hero-signature.visible {
    opacity: 1;
    transform: translateY(0);
}

/* 内层 wrapper */
.signature-inner {
    width: 100%;
}

.signature-inner svg {
    width: 100%;
    height: auto;
    overflow: hidden;
    transition: filter 1.5s ease-out;
}

/* 签名动画完成后的发光效果 — 与橙金→粉→青渐变协调 */
.signature-inner .svg-glow {
    filter: drop-shadow(0 0 3px rgba(245, 158, 11, 0.5))
            drop-shadow(0 0 8px rgba(244, 114, 182, 0.3))
            drop-shadow(0 0 16px rgba(34, 211, 238, 0.2));
    animation: signature-glow 3.5s ease-in-out infinite;
}

/* 移动端性能优化：禁用耗性能的发光效果和非必要动画 */
@media (max-width: 768px) {
    .signature-inner .svg-glow {
        filter: none;
        animation: none;
    }

    /* 禁用背景装饰动画 */
    .hero-bg-orb,
    .hero-bg-orb-1,
    .hero-bg-orb-2,
    .hero-bg-orb-3,
    .hero-bg-orb-4 {
        animation: none !important;
        opacity: 0.3;
    }

    /* 禁用浮动光晕 */
    .about-float-a,
    .about-float-b,
    .about-float-c,
    .about-float-d {
        animation: none !important;
        opacity: 0.5;
    }

    /* 禁用头像呼吸光效 */
    .avatar-breathe,
    .avatar-pulse {
        animation: none !important;
    }

    /* 禁用滚动字幕动画 */
    .marquee-inner {
        animation: none !important;
    }

    /* 禁用数字闪光 */
    .number-shimmer {
        animation: none !important;
    }

    /* 禁用月光呼吸效果 */
    .moon-breathe,
    .moon-glow,
    .pulse-ring-1,
    .pulse-ring-2,
    .pulse-ring-3 {
        animation: none !important;
        opacity: 0.5;
    }

    /* 禁用页脚装饰动画 */
    .footer-dot-pulse {
        animation: none !important;
    }

    /* 保留必要动画：光标闪烁、状态脉冲 */
    /* .cursor-blink, .statusPulse 保持不变 */
}

/* 尊重用户偏好：减少动画 */
@media (prefers-reduced-motion: reduce) {
    .signature-inner .svg-glow {
        animation: none;
        filter: drop-shadow(0 0 4px rgba(245, 158, 11, 0.3));
    }
}

/* 柔和脉冲发光 */
@keyframes signature-glow {
    0%, 100% {
        filter: drop-shadow(0 0 2px rgba(245, 158, 11, 0.3))
                drop-shadow(0 0 6px rgba(244, 114, 182, 0.15))
                drop-shadow(0 0 12px rgba(34, 211, 238, 0.1));
    }
    50% {
        filter: drop-shadow(0 0 5px rgba(245, 158, 11, 0.6))
                drop-shadow(0 0 12px rgba(244, 114, 182, 0.35))
                drop-shadow(0 0 24px rgba(34, 211, 238, 0.25));
    }
}

/* 签名 path 默认样式（由 JS 动态设置 stroke-dashoffset 动画） */
.signature-inner svg path {
    /* JS 会动态设置 stroke / fill / stroke-dasharray / stroke-dashoffset */
}



