/* ============================================ */
/* about.css */
/* ============================================ */

/* ============================================================
   ABOUT MODULE
   Auto-generated by split-css.js
   ============================================================ */

/* ============================================================
   ABOUT GRID — 2×2 等宽网格，工整精致
   ============================================================ */
.about-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    max-width: 1060px;
    margin: 0 auto;
    padding: 0 var(--space-sm);
}

.about-grid-sub {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
}

/* ---- 卡片浮动微动效（无旋转、无偏移） ---- */
.about-card:nth-child(1) {
    animation: about-float-a 6s ease-in-out infinite;
}
.about-grid-sub .about-card:nth-child(1) {
    animation: about-float-a 6s ease-in-out 1.5s infinite;
}
.about-grid-sub .about-card:nth-child(2) {
    animation: about-float-a 6s ease-in-out 3s infinite;
}
.about-grid-sub .about-card:nth-child(3) {
    animation: about-float-a 6s ease-in-out 4.5s infinite;
}

@keyframes about-float-a {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
}

/* hover 时暂停浮动 + 上浮 */
.about-card:hover {
    animation-play-state: paused;
    transform: translateY(-8px) scale(1.025);
}

/* ===== 卡片主体 ===== */
.about-card {
    padding: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    position: relative;
    overflow: hidden;
    border-radius: 16px;
    transition: transform 0.5s cubic-bezier(0.25, 0.1, 0.25, 1), 
                box-shadow 0.5s cubic-bezier(0.25, 0.1, 0.25, 1),
                background 0.4s ease,
                border-color 0.4s ease;
}

/* ===== 顶部渐变光条（统一 + 每卡片不同配色） ===== */
.about-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: 5%;
    right: 5%;
    height: 2px;
    background: linear-gradient(90deg,
        transparent 0%,
        var(--accent-blue) 25%,
        var(--accent-purple) 50%,
        var(--accent-cyan) 75%,
        transparent 100%
    );
    border-radius: 0 0 2px 2px;
    opacity: 0;
    transition: opacity 0.5s ease, left 0.5s ease, right 0.5s ease;
    z-index: 2;
}
.about-card:nth-child(1)::after {
    background: linear-gradient(90deg, transparent, var(--accent-blue), var(--accent-cyan), transparent);
}
.about-grid-sub .about-card:nth-child(1)::after {
    background: linear-gradient(90deg, transparent, var(--accent-purple), var(--accent-blue), transparent);
}
.about-grid-sub .about-card:nth-child(2)::after {
    background: linear-gradient(90deg, transparent, var(--accent-cyan), var(--accent-purple), transparent);
}
.about-grid-sub .about-card:nth-child(3)::after {
    background: linear-gradient(90deg, transparent, #c084fc, var(--accent-purple), transparent);
}

.about-card:hover::after {
    opacity: 1;
    left: 0;
    right: 0;
}

/* ===== 底部装饰渐变条（新） ===== */
.about-card::before {
    content: '';
    position: absolute;
    bottom: 0;
    left: 10%;
    right: 10%;
    height: 1.5px;
    background: linear-gradient(90deg, transparent, var(--card-accent, var(--accent-blue)), transparent);
    opacity: 0.15;
    transition: opacity 0.5s ease, left 0.5s ease, right 0.5s ease;
    z-index: 2;
}
.about-card:hover::before {
    opacity: 0.6;
    left: 5%;
    right: 5%;
}

/* ===== 序号水印 ===== */
.card-number {
    position: absolute;
    top: -0.8rem;
    right: 0.6rem;
    font-family: var(--font-mono);
    font-size: 5.5rem;
    font-weight: 800;
    color: rgba(255, 255, 255, 0.02);
    line-height: 1;
    pointer-events: none;
    z-index: 0;
    transition: color 0.6s ease, transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
    /* 流光效果 */ 
    background: linear-gradient(135deg, 
        rgba(255,255,255,0) 30%,
        rgba(255,255,255,0.03) 50%,
        rgba(255,255,255,0) 70%);
    background-size: 200% 200%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: number-shimmer 4s ease-in-out infinite;
}

@keyframes number-shimmer {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
}

.about-card:hover .card-number {
    color: rgba(79, 140, 255, 0.08);
    transform: scale(1.15) translateY(-6px) rotate(-2deg);
}

/* ===== 插图区域 ===== */
.card-illustration {
    width: 110px;
    height: 110px;
    padding: var(--space-lg) 0 0 0;
    color: rgba(255, 255, 255, 0.45);
    transition: color 0.5s ease, transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
    position: relative;
    z-index: 1;
    flex-shrink: 0;
    margin: 0 auto;
    /* 插图呼吸动画 */
    animation: illus-breathe 6s ease-in-out infinite;
}

@keyframes illus-breathe {
    0%, 100% { transform: scale(1); }
    33% { transform: scale(1.04); }
    66% { transform: scale(0.97); }
}

.card-illustration svg {
    width: 100%;
    height: 100%;
    display: block;
}

.about-card:hover .card-illustration {
    color: rgba(255, 255, 255, 0.95);
    transform: scale(1.1);
    animation: none;
}

/* ===== 标题 ===== */
.card-title {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    padding: var(--space-sm) var(--space-lg) 0;
    position: relative;
    z-index: 1;
    transition: letter-spacing 0.4s ease;
    width: 100%;
}

.about-card:hover .card-title {
    letter-spacing: 0.06em;
}

/* 标题下划线 */
.card-title::after {
    content: '';
    display: block;
    width: 2.5rem;
    height: 2.5px;
    margin: 0.4rem auto 0;
    border-radius: 2px;
    background: linear-gradient(90deg, var(--accent-blue), var(--accent-purple));
    transition: width 0.5s cubic-bezier(0.34, 1.56, 0.64, 1), 
                background 0.5s ease;
}

.about-card:hover .card-title::after {
    width: 5rem;
    background: linear-gradient(90deg, var(--accent-cyan), var(--accent-blue), var(--accent-purple));
}

/* 英文副标题 */
.card-subtitle {
    display: inline-block;
    font-family: 'Inter', 'Fira Code', monospace;
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.35);
    margin-top: 0.25rem;
    transition: color 0.4s ease, letter-spacing 0.4s ease;
}

.about-card:hover .card-subtitle {
    letter-spacing: 0.18em;
}

.explore-card:hover .card-subtitle { color: rgba(168, 85, 247, 0.7); }
.tech-card:hover .card-subtitle { color: rgba(34, 211, 238, 0.7); }
.create-card:hover .card-subtitle { color: rgba(250, 204, 21, 0.7); }

/* ===== 描述文字 ===== */
.card-desc {
    font-size: 0.88rem;
    color: var(--text-secondary);
    line-height: 1.8;
    letter-spacing: 0.01em;
    padding: var(--space-sm) var(--space-lg) var(--space-lg);
    position: relative;
    z-index: 1;
    transition: color 0.4s ease;
    width: 100%;
}

.about-card:hover .card-desc {
    color: var(--text-primary);
}

.card-desc strong {
    color: var(--text-primary);
    font-weight: 700;
}

/* ============================================================
   ABOUT 卡片 01 — 全宽幻灯片轮播
   ============================================================ */
.about-card-hero {
    grid-column: 1 / -1;
    padding: var(--space-xl) var(--space-xl) !important;
    text-align: left;
    position: relative;
    overflow: hidden;
}

/* C2: 轮播卡片独立微光 — 比普通卡片更精致 */
.about-card-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(
        500px circle at var(--mouse-x, 50%) var(--mouse-y, 50%),
        rgba(79, 140, 255, 0.07) 0%,
        rgba(168, 85, 247, 0.04) 30%,
        transparent 70%
    );
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
    z-index: 0;
}

.about-card-hero:hover::before {
    opacity: 1;
}

.about-card-hero .card-number {
    font-size: 8rem;
    top: -2rem;
    right: 1rem;
}

.about-hero-layout {
    width: 100%;
    position: relative;
    z-index: 1;
}

/* ============================================================
   Slide 3：image-mosaic — 4×4 拼图逐块揭示 (Piece by Piece)
   ============================================================ */
.hero-slide-image.image-mosaic .gallery-image-wrapper {
    position: relative;
    overflow: hidden;
    border-radius: 12px;
    border: none;
    box-shadow: 0 6px 30px -6px rgba(200, 180, 140, 0.08);
    transition: box-shadow 0.8s ease;
}

.hero-slide-image.image-mosaic .gallery-image-wrapper img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 12px;
}

/* 拼图瓦片覆盖层 */
.mosaic-tile {
    position: absolute;
    background: #1a1e2b;
    pointer-events: none;
    z-index: 5;
    opacity: 1;
    transition: opacity 0.45s cubic-bezier(0.16, 1, 0.3, 1),
                background 0.45s ease;
    /* 瓦片之间有微小间隔，模拟拼图缝隙 */
    outline: 1px solid rgba(255, 255, 255, 0.04);
}

/* 瓦片消失后露出图片 */
.mosaic-tile.revealed {
    opacity: 0;
    background: transparent;
}

/* 完成后的微光 */
.hero-slide-image.image-mosaic .gallery-image-wrapper.mosaic-done {
    box-shadow: 0 12px 48px -8px rgba(200, 180, 140, 0.22);
}

.hero-slide-image.image-mosaic .gallery-image-wrapper.mosaic-done img {
    transform: scale(1.03);
    filter: brightness(1.06);
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1),
                filter 0.8s ease;
}

/* hover */
.hero-slide-image.image-mosaic .gallery-image-wrapper.mosaic-done:hover img {
    transform: scale(1.08);
    filter: brightness(1.12);
}

/* 图片加载失败占位 */
.hero-slide-image .gallery-image-wrapper.gallery-fallback {
    background: rgba(255, 255, 255, 0.02);
}

.hero-slide-image .gallery-fallback-content {
    display: none;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-muted);
}

.hero-slide-image .gallery-image-wrapper.gallery-fallback .gallery-fallback-content {
    display: flex;
}

.hero-slide-image .gallery-fallback-content svg {
    width: 48px;
    height: 48px;
    opacity: 0.4;
}

.hero-slide-image .gallery-fallback-content span {
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    opacity: 0.5;
}

/* ============================================================
   轮播控制栏 — 玻璃拟态风格
   ============================================================ */

/* 控制栏容器 */
.about-hero-layout > .carousel-dots {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 6px;
    margin-top: 12px;
    opacity: 0.55;
    transition: opacity 0.4s ease;
}
.about-hero-layout > .carousel-dots:hover {
    opacity: 1;
}

.carousel-dots-inner {
    display: flex;
    align-items: center;
    gap: 10px;
}

/* 通用按钮基底 — 左右箭头 + 暂停按钮共用 */
.carousel-dots .carousel-prev,
.carousel-dots .carousel-next,
.carousel-pause-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px) saturate(1.2);
    -webkit-backdrop-filter: blur(12px) saturate(1.2);
    color: rgba(255, 255, 255, 0.45);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    transition:
        background 0.3s ease,
        border-color 0.3s ease,
        color 0.3s ease,
        box-shadow 0.3s ease,
        transform 0.2s ease;
    flex-shrink: 0;
}

/* hover 效果 */
.carousel-dots .carousel-prev:hover,
.carousel-dots .carousel-next:hover,
.carousel-pause-btn:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.2);
    color: rgba(255, 255, 255, 0.85);
    box-shadow: 0 0 16px rgba(79, 140, 255, 0.15);
    transform: scale(1.08);
}

/* 暂停按钮特殊间距 */
.carousel-pause-btn {
    margin: 0 4px;
}

/* 暂停按钮激活状态（已暂停） */
.carousel-pause-btn[aria-pressed="true"] {
    border-color: rgba(79, 140, 255, 0.35);
    box-shadow: 0 0 14px rgba(79, 140, 255, 0.2);
    color: var(--accent-blue);
}

/* SVG 图标尺寸 */
.carousel-dots .carousel-prev svg,
.carousel-dots .carousel-next svg,
.carousel-pause-btn svg {
    width: 16px;
    height: 16px;
    transition: transform 0.2s ease;
}

/* 底部指示器圆点 */
.carousel-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    border: none;
    background: rgba(255, 255, 255, 0.25);
    cursor: pointer;
    padding: 0;
    transition:
        width 0.4s cubic-bezier(0.16, 1, 0.3, 1),
        background 0.4s ease,
        box-shadow 0.4s ease,
        transform 0.3s ease;
    flex-shrink: 0;
}

.carousel-dot:hover {
    background: rgba(255, 255, 255, 0.55);
    transform: scale(1.3);
}

/* 活跃状态 — 胶囊形 */
.carousel-dot.active {
    width: 22px;
    border-radius: 3px;
    background: var(--accent-blue);
    box-shadow: 0 0 10px rgba(79, 140, 255, 0.4);
}






/* ---- 左侧 SVG 图标（Slide 1 标题区） ---- */
.hero-eyebrow-icon {
    display: block;
    width: 96px !important;
    height: 80px !important;
    max-width: 96px;
    max-height: 80px;
    flex-shrink: 0;
    color: rgba(255, 255, 255, 0.35);
    transition: color 0.4s ease;
}

.about-card-hero:hover .hero-eyebrow-icon {
    color: var(--accent-blue);
}

/* ---- 标题行（SVG 左 + 文字组右，横向排列） ---- */
.hero-header-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.4rem;
    opacity: 0;
    transform: translateX(-20px);
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1), transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
}

.hero-title-block {
    display: flex;
    flex-direction: column;
    position: relative;
    z-index: 1;
    overflow: visible;
    flex: 1 1 auto;
    min-width: max-content;
}

.hero-header-row.header-visible {
    opacity: 1;
    transform: translateX(0);
}

/* ---- Eyebrow 升级：渐变色彩 ---- */
.hero-eyebrow {
    position: relative;
    z-index: 2;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-bottom: 0.2rem;
    background: linear-gradient(135deg, var(--accent-blue) 0%, var(--accent-cyan) 50%, var(--accent-purple) 100%);
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: shimmer 4s linear infinite;
}

/* ---- Slide 1 主标题升级 ---- */
.hero-main-title {
    text-align: left !important;
    padding: 0 !important;
    position: relative;
    z-index: 2;
    font-size: 2rem !important;
    line-height: 1.15 !important;
    letter-spacing: 0.03em;
    font-weight: 700;
}

.hero-main-title::after {
    margin: 0.4rem 0 0 !important;
    width: 16rem !important;
}

/* ---- Slide 2/3 标题：匹配第一张卡片的排版 ---- */
.hero-title-block .card-title {
    text-align: left !important;
    padding: 0 !important;
    font-size: 2rem !important;
    line-height: 1.15 !important;
    font-weight: 700;
    letter-spacing: 0.03em;
}

.hero-title-block .card-title::after {
    margin: 0.4rem 0 0 !important;
    width: 14rem !important;
}

/* ---- Valkjin 大名字：手写签名风格 -> 水印底纹 ---- */
.hero-name-large {
    display: block;
    font-family: 'Dancing Script', 'Trebuchet MS', cursive, sans-serif;
    font-size: 2.6rem;
    font-weight: 600;
    font-style: normal;
    letter-spacing: 0.01em;
    line-height: 1.1;
    margin: 0.55rem 0 0.7rem 0;
    white-space: nowrap;
    pointer-events: none;
    position: relative;
    z-index: 0;
    background: linear-gradient(135deg, #8b9dc3 0%, #bcc6d6 30%, #d6dbe4 55%, #9aabbf 75%, #bfc8d4 100%);
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: shimmer 4s linear infinite;
    /* 逐行动画：初始隐藏 */
    opacity: 0;
    transform: translateY(16px) rotate(-1.5deg);
    transition: opacity 0.65s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.65s cubic-bezier(0.16, 1, 0.3, 1);
}

.hero-name-large.line-visible {
    opacity: 1;
    transform: translateY(0) rotate(0deg);
    animation: shimmer 4s linear infinite,
               signature-watermark 3.5s 2s cubic-bezier(0.33, 1, 0.68, 1) forwards;
}

@keyframes signature-watermark {
    0% {
        transform: translateY(0) rotate(0deg) scale(1);
        opacity: 1;
    }
    100% {
        transform: translateY(0) rotate(0deg) scale(3.8);
        opacity: 0.08;
    }
}

@keyframes shift-up-after-watermark {
    0% {
        transform: translateY(0) scale(1);
        text-shadow: 0 0 0 transparent;
        opacity: 1;
    }
    100% {
        transform: translateY(-1.5rem) scale(1.08);
        text-shadow: 0 0 20px rgba(160, 200, 255, 0.35);
        opacity: 1;
    }
}

/* ---- Slide 3: The Architect 蓝图角标效果 ---- */
.hero-slide:nth-child(3) .hero-name-large {
    position: relative;
}

.hero-slide:nth-child(3) .hero-name-large::before,
.hero-slide:nth-child(3) .hero-name-large::after {
    content: '';
    position: absolute;
    width: 22px;
    height: 22px;
    border-color: rgba(180, 200, 228, 0.28);
    border-style: solid;
    pointer-events: none;
    z-index: -1;
    opacity: 0;
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1);
}

.hero-slide:nth-child(3) .hero-name-large::before {
    top: -6px;
    left: -12px;
    border-width: 1.5px 0 0 1.5px;
}

.hero-slide:nth-child(3) .hero-name-large::after {
    bottom: -6px;
    right: -12px;
    border-width: 0 1.5px 1.5px 0;
}

.hero-slide:nth-child(3).slide-active .hero-name-large.line-visible::before,
.hero-slide:nth-child(3).slide-active .hero-name-large.line-visible::after {
    opacity: 1;
    animation: blueprint-bracket-breathe 3.2s ease-in-out infinite;
}

/* 蓝图角标呼吸 */
@keyframes blueprint-bracket-breathe {
    0%, 100% { border-color: rgba(180, 200, 228, 0.28); }
    50%      { border-color: rgba(180, 200, 228, 0.5); }
}

/* ---- 角色标签升级 ---- */
.hero-role {
    display: block;
    font-size: 0.92rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    color: var(--text-secondary);
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
}

.hero-role.line-visible {
    opacity: 0.75;
    transform: translateY(0);
    animation: shift-up-after-watermark 0.7s 5.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

/* ---- 轮播内标语文字微调 ---- */
.hero-desc .hero-tagline {
    display: block;
    font-size: 0.92rem;
    line-height: 1.8;
    color: var(--text-muted);
    margin-top: 0.1rem;
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
}

.hero-desc .hero-tagline.line-visible {
    opacity: 1;
    transform: translateY(0);
    animation: shift-up-after-watermark 0.7s 5.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

/* ---- 详情条目 ---- */
.about-hero-details {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    width: 100%;
    margin-top: auto;
}

.hero-detail-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.82rem;
    color: var(--text-secondary);
    line-height: 1.5;
    padding: 0.55rem 0.75rem;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.015);
    border-left: 2px solid transparent;
    opacity: 0;
    transform: translateX(-12px);
    transition: background 0.35s ease, border-color 0.35s ease, color 0.35s ease,
                transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s ease,
                opacity 0.55s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    overflow: hidden;
    cursor: default;
}

/* 入场弹性：在 detail-visible 基础上叠加弹性回弹 */
.hero-detail-item.detail-visible {
    opacity: 1;
    transform: translateX(0);
    animation: detail-item-bounce 0.65s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}

@keyframes detail-item-bounce {
    0% {
        opacity: 0;
        transform: translateX(-16px) scale(0.96);
    }
    55% {
        opacity: 1;
        transform: translateX(4px) scale(1.02);
    }
    100% {
        opacity: 1;
        transform: translateX(0) scale(1);
    }
}

/* 不同条目不同强调色 */
.hero-detail-item:nth-child(1).detail-visible { border-left-color: var(--accent-blue); }
.hero-detail-item:nth-child(2).detail-visible { border-left-color: var(--accent-cyan); }
.hero-detail-item:nth-child(3).detail-visible { border-left-color: var(--accent-purple); }
.hero-detail-item:nth-child(4).detail-visible { border-left-color: var(--accent-blue); }

/* 边框脉冲呼吸光效 */
.hero-detail-item.detail-visible::before {
    content: '';
    position: absolute;
    left: -2px;
    top: 12%;
    height: 76%;
    width: 2px;
    border-radius: 1px;
    opacity: 0;
    pointer-events: none;
    z-index: 0;
    animation: detail-border-glow 2.8s ease-in-out infinite;
}

.hero-detail-item:nth-child(1).detail-visible::before { background: var(--accent-blue); animation-delay: 0s; }
.hero-detail-item:nth-child(2).detail-visible::before { background: var(--accent-cyan); animation-delay: 0.5s; }
.hero-detail-item:nth-child(3).detail-visible::before { background: var(--accent-purple); animation-delay: 1s; }
.hero-detail-item:nth-child(4).detail-visible::before { background: var(--accent-blue); animation-delay: 1.5s; }

@keyframes detail-border-glow {
    0%, 100% { opacity: 0.15; box-shadow: 0 0 6px 2px transparent; }
    50% { opacity: 0.8; box-shadow: 0 0 12px 3px currentColor; }
}

.hero-detail-item:hover {
    background: rgba(255, 255, 255, 0.04);
    color: var(--text-primary);
    transform: translateY(-2px);
    box-shadow: 0 4px 14px -4px rgba(0, 0, 0, 0.15), inset 0 1px 0 rgba(255, 255, 255, 0.03);
}

/* hover 时 pulse 加强 */
.hero-detail-item:hover::before {
    animation: detail-border-glow-hover 1s ease-in-out infinite;
}

@keyframes detail-border-glow-hover {
    0%, 100% { opacity: 0.5; box-shadow: 0 0 8px 2px transparent; }
    50% { opacity: 1; box-shadow: 0 0 18px 4px currentColor; }
}

/* 图标 */
.hero-detail-item .detail-icon {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    color: var(--accent-blue);
    opacity: 0.55;
    transform: rotate(-10deg) scale(0.8);
    transition: opacity 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) 0.15s, transform 0.45s cubic-bezier(0.34, 1.56, 0.64, 1) 0.15s, color 0.35s ease;
}

.hero-detail-item.detail-visible .detail-icon {
    opacity: 0.85;
    transform: rotate(0deg) scale(1);
}

.hero-detail-item:hover .detail-icon {
    opacity: 1;
    transform: scale(1.15);
}

.hero-detail-item:nth-child(1) .detail-icon { color: var(--accent-blue); }
.hero-detail-item:nth-child(2) .detail-icon { color: var(--accent-cyan); }
.hero-detail-item:nth-child(3) .detail-icon { color: var(--accent-purple); }
.hero-detail-item:nth-child(4) .detail-icon { color: var(--accent-blue); }

.hero-detail-item .detail-icon svg {
    width: 100%;
    height: 100%;
    display: block;
}

/* 标签文字 */
.detail-label {
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--text-primary);
}

.detail-tag {
    font-size: 0.72rem;
    padding: 0.15rem 0.45rem;
    border-radius: 4px;
    background: rgba(79, 140, 255, 0.08);
    color: var(--accent-blue);
    letter-spacing: 0.03em;
    white-space: nowrap;
    margin-left: auto;
    opacity: 0;
    transform: translateX(6px);
    transition: opacity 0.4s ease 0.35s, transform 0.4s ease 0.35s, background 0.35s ease, color 0.35s ease;
}

.hero-detail-item.detail-visible .detail-tag {
    opacity: 1;
    transform: translateX(0);
}

.hero-detail-item:nth-child(2) .detail-tag { background: rgba(34, 211, 238, 0.08); color: var(--accent-cyan); }
.hero-detail-item:nth-child(3) .detail-tag { background: rgba(168, 85, 247, 0.08); color: var(--accent-purple); }
.hero-detail-item:nth-child(4) .detail-tag { background: rgba(79, 140, 255, 0.08); color: var(--accent-blue); }

.hero-detail-item:hover .detail-tag {
    background: rgba(79, 140, 255, 0.15);
}

/* ========== 可折叠卡片 body ========== */
.card-fold-body {
    overflow: hidden;
    width: 100%;
    position: relative;
    z-index: 1;
    transition: max-height 0.55s cubic-bezier(0.25, 0.1, 0.25, 1),
                opacity 0.4s ease;
}

.card-fold-body.collapsed {
    max-height: 0 !important;
    opacity: 0;
    pointer-events: none;
}

.card-fold-body:not(.collapsed) {
    max-height: 1200px;
    opacity: 1;
}

/* ===== 图文混排区域 ===== */
.card-content-row {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin: 8px 0 14px;
    padding: 0 var(--space-md);
}

.card-content-text {
    width: 100%;
}

/* 图片容器 — 玻璃拟态相框 */
.card-content-visual {
    position: relative;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow:
        0 8px 32px rgba(0, 0, 0, 0.35),
        inset 0 1px 0 rgba(255, 255, 255, 0.04);
    transition:
        box-shadow 0.5s ease,
        border-color 0.5s ease,
        transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
}

/* 各卡片专属光晕色 */
.explore-card .card-content-visual {
    box-shadow:
        0 8px 32px rgba(0, 0, 0, 0.35),
        0 0 40px rgba(168, 85, 247, 0.06);
}
.tech-card .card-content-visual {
    box-shadow:
        0 8px 32px rgba(0, 0, 0, 0.35),
        0 0 40px rgba(34, 211, 238, 0.06);
}
.create-card .card-content-visual {
    box-shadow:
        0 8px 32px rgba(0, 0, 0, 0.35),
        0 0 40px rgba(250, 204, 21, 0.06);
}

/* hover 光晕增强 */
.explore-card .card-content-visual:hover,
.explore-card:hover .card-content-visual {
    border-color: rgba(168, 85, 247, 0.2);
    box-shadow:
        0 12px 40px rgba(0, 0, 0, 0.45),
        0 0 60px rgba(168, 85, 247, 0.15);
    transform: translateY(-2px);
}
.tech-card .card-content-visual:hover,
.tech-card:hover .card-content-visual {
    border-color: rgba(34, 211, 238, 0.2);
    box-shadow:
        0 12px 40px rgba(0, 0, 0, 0.45),
        0 0 60px rgba(34, 211, 238, 0.15);
    transform: translateY(-2px);
}
.create-card .card-content-visual:hover,
.create-card:hover .card-content-visual {
    border-color: rgba(250, 204, 21, 0.2);
    box-shadow:
        0 12px 40px rgba(0, 0, 0, 0.45),
        0 0 60px rgba(250, 204, 21, 0.15);
    transform: translateY(-2px);
}


/* 图片本身 — 初始隐藏，展开后动画入场 */
.card-content-visual .card-preview-img {
    width: 100%;
    display: block;
    opacity: 0;
    transform: translateY(16px) scale(0.96);
    filter: blur(6px);
    transition:
        opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1),
        transform 0.6s cubic-bezier(0.16, 1, 0.3, 1),
        filter 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: 0.25s;
}

/* 卡片展开 → 图片浮现 */
.card-fold-body:not(.collapsed) .card-content-visual .card-preview-img {
    opacity: 0.9;
    transform: translateY(0) scale(1);
    filter: blur(0);
}

/* hover 增强 — 立即响应，不等延迟 */
.card-content-visual:hover .card-preview-img {
    opacity: 1;
    transform: scale(1.04);
    filter: blur(0);
    transition-delay: 0s;
}


/* ========== 折叠切换按钮 ========== */
.card-fold-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    margin: 0.5rem auto 0.2rem;
    padding: 0;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.025);
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    z-index: 2;
}

.card-fold-toggle:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.2);
    color: var(--text-primary);
    transform: scale(1.12);
}

.card-fold-toggle .fold-icon {
    width: 12px;
    height: 12px;
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.card-fold-toggle[aria-expanded="true"] .fold-icon {
    transform: rotate(180deg);
}

/* 卡片 hover 时 toggle 按钮微亮 */
.about-card:hover .card-fold-toggle {
    border-color: rgba(255, 255, 255, 0.15);
    background: rgba(255, 255, 255, 0.05);
}

/* ========== 折叠占位区（哲理语句） ========== */
.card-fold-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    padding: 0.8rem 1rem 0.5rem;
    max-height: 120px;
    opacity: 1;
    overflow: visible;
    position: relative;
    z-index: 1;
    transition: max-height 0.55s cubic-bezier(0.25, 0.1, 0.25, 1),
                opacity 0.4s ease,
                padding 0.45s ease,
                margin 0.45s ease;
}

/* 当内容区展开时，占位区收合 */
.card-fold-body:not(.collapsed) ~ .card-fold-placeholder {
    max-height: 0 !important;
    opacity: 0;
    padding-top: 0;
    padding-bottom: 0;
    margin-top: 0;
    margin-bottom: 0;
    pointer-events: none;
}

.fold-quote {
    font-size: 0.95rem;
    color: var(--text-secondary);
    font-style: italic;
    letter-spacing: 0.05em;
    line-height: 1.6;
    text-align: center;
    margin: 0;
    transition: color 0.35s ease;
}

.fold-quote-ref {
    font-size: 0.72rem;
    color: var(--text-muted);
    margin: 0;
    letter-spacing: 0.04em;
}

/* ===== 粒子漂浮背景 ===== */
.placeholder-particles {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
}

.p-dot {
    position: absolute;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.12);
    box-shadow: 0 0 6px rgba(255, 255, 255, 0.06);
    animation: p-float 6s ease-in-out infinite;
}

/* 4 种浮动路径，任意交替 */
.p-dot.a1 { animation-name: p-float1; animation-duration: 5.2s; }
.p-dot.a2 { animation-name: p-float2; animation-duration: 6.8s; }
.p-dot.a3 { animation-name: p-float3; animation-duration: 7.4s; }
.p-dot.a4 { animation-name: p-float4; animation-duration: 6.0s; }

/* 各卡片粒子专属色 */
.explore-card .p-dot {
    background: rgba(168, 85, 247, 0.22);
    box-shadow: 0 0 8px rgba(168, 85, 247, 0.12);
}
.tech-card .p-dot {
    background: rgba(34, 211, 238, 0.22);
    box-shadow: 0 0 8px rgba(34, 211, 238, 0.12);
}
.create-card .p-dot {
    background: rgba(250, 204, 21, 0.22);
    box-shadow: 0 0 8px rgba(250, 204, 21, 0.12);
}

/* hover 卡片时粒子微亮 */
.explore-card:hover .p-dot { background: rgba(168, 85, 247, 0.35); }
.tech-card:hover .p-dot      { background: rgba(34, 211, 238, 0.35); }
.create-card:hover .p-dot    { background: rgba(250, 204, 21, 0.35); }

/* 卡片折叠时暂停粒子动画，节省性能 */
.card-fold-body.collapsed .placeholder-particles,
.card-fold-body.collapsed .p-dot {
    animation-play-state: paused;
    opacity: 0;
    transition: opacity 0.4s ease;
}

@keyframes p-float1 {
    0%, 100% { transform: translate(0, 0)   scale(1);   opacity: 0.25; }
    25%      { transform: translate(18px, -14px) scale(1.3); opacity: 0.4;  }
    50%      { transform: translate(-10px, -28px) scale(0.8); opacity: 0.15; }
    75%      { transform: translate(-20px, -6px)  scale(1.1); opacity: 0.35; }
}

@keyframes p-float2 {
    0%, 100% { transform: translate(0, 0)   scale(1);   opacity: 0.2; }
    33%      { transform: translate(-22px, -18px) scale(1.3); opacity: 0.35; }
    66%      { transform: translate(16px, -26px)  scale(0.7); opacity: 0.12; }
}

@keyframes p-float3 {
    0%, 100% { transform: translate(0, 0)   scale(0.9); opacity: 0.2; }
    50%      { transform: translate(14px, -22px) scale(1.2); opacity: 0.35; }
}

@keyframes p-float4 {
    0%, 100% { transform: translate(0, 0)   scale(1);   opacity: 0.15; }
    30%      { transform: translate(-16px, -8px)  scale(1.4); opacity: 0.35; }
    60%      { transform: translate(20px, -20px)  scale(0.7); opacity: 0.1; }
    85%      { transform: translate(8px, -30px)   scale(1.1); opacity: 0.25; }
}

/* 卡片 hover 时哲理语句显示个性色 */
.explore-card:hover .fold-quote { color: rgba(168, 85, 247, 0.85); }
.tech-card:hover .fold-quote { color: rgba(34, 211, 238, 0.85); }
.create-card:hover .fold-quote { color: #c084fc; }

/* ===== 每张卡片的个性化配色变量 ===== */
.about-card:nth-child(1) {
    --card-glow: rgba(79, 140, 255, 0.12);
    --card-accent: var(--accent-blue);
}
.about-grid-sub .about-card:nth-child(1) {
    --card-glow: rgba(168, 85, 247, 0.12);
    --card-accent: var(--accent-purple);
}
.about-grid-sub .about-card:nth-child(2) {
    --card-glow: rgba(34, 211, 238, 0.12);
    --card-accent: var(--accent-cyan);
}
.about-grid-sub .about-card:nth-child(3) {
    --card-glow: rgba(192, 132, 252, 0.12);
    --card-accent: #c084fc;
}

/* hover 增强光晕 */
.about-card {
    will-change: transform, box-shadow;
}

.about-card:hover {
    background: var(--glass-hover);
    border-color: rgba(255, 255, 255, 0.22);
    box-shadow:
        0 20px 60px rgba(0, 0, 0, 0.6),
        0 0 0 1px rgba(79, 140, 255, 0.2) inset,
        0 0 120px var(--card-glow);
}

/* ============================================================
   SKILLS — 星座星图 (Constellation Star Chart)
   Canvas 绘制连线 + 绝对定位节点环绕
   ============================================================ */
.constellation {
    position: relative;
    width: 100%;
    max-width: 780px;
    margin: 0 auto;
    aspect-ratio: 1 / 1;
    max-height: 700px;
    overflow: visible;
}

/* Canvas 连线层 */
.constellation-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    opacity: 0;
    transition: opacity 1.2s ease 0.3s;
}

.constellation.active .constellation-canvas {
    opacity: 1;
}

/* Canvas 淡出 - 收拢时使用更快的淡出速度 */
.constellation-canvas.fading-out {
    opacity: 0;
    transition: opacity 0.5s ease;
}

/* 中央星核 — 多层次发光核心 */
.constellation-core {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 2;
    pointer-events: none;
    transition: transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* 未激活状态：核心可点击 */
.constellation:not(.active) .constellation-core {
    pointer-events: auto;
    cursor: pointer;
}

/* ========================================
   核心光球 — 月球效果
   ======================================== */

/* 月球球体呼吸 — 极缓慢、极微弱 */
@keyframes moon-breathe {
    0%, 100% { transform: translate(-50%, -50%) scale(1); }
    50%      { transform: translate(-50%, -50%) scale(1.008); }
}

/* 月晕微光 — 极缓慢微弱 */
@keyframes moon-glow {
    0%, 100% { opacity: 0.35; }
    50%      { opacity: 0.5; }
}

.core-dot {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    /* 月晕 — 暖银白辉光（更柔和） */
    box-shadow:
        0 0 12px 3px rgba(220, 215, 200, 0.3),
        0 0 40px 10px rgba(200, 195, 180, 0.12),
        0 0 90px 24px rgba(180, 175, 160, 0.04),
        0 0 160px 48px rgba(160, 155, 140, 0.02);
    /*
       月球表面纹理：
       - 底层球形明暗 (光照从左上)
       - 中层月海暗斑
       - 顶层环形山 (多个小圆暗点)
    */
    background:
        /* — 环形山 — */
        radial-gradient(circle at 28% 24%, rgba(195, 188, 172, 0.55) 3px, transparent 3.5px),
        radial-gradient(circle at 56% 36%, rgba(185, 178, 162, 0.5) 4.5px, transparent 5px),
        radial-gradient(circle at 40% 54%, rgba(175, 168, 152, 0.6) 3.5px, transparent 4px),
        radial-gradient(circle at 66% 30%, rgba(188, 181, 165, 0.4) 2.8px, transparent 3.2px),
        radial-gradient(circle at 34% 62%, rgba(180, 173, 157, 0.45) 4px, transparent 4.5px),
        radial-gradient(circle at 52% 20%, rgba(190, 183, 167, 0.35) 2.5px, transparent 3px),
        radial-gradient(circle at 72% 50%, rgba(182, 175, 159, 0.4) 3px, transparent 3.5px),
        radial-gradient(circle at 22% 42%, rgba(192, 185, 169, 0.35) 2.2px, transparent 2.8px),
        radial-gradient(circle at 60% 62%, rgba(178, 171, 155, 0.35) 2px, transparent 2.5px),
        /* — 月海 (暗色平原区) — */
        radial-gradient(ellipse at 38% 40%, rgba(192, 186, 172, 0.25) 18%, transparent 52%),
        radial-gradient(ellipse at 58% 50%, rgba(188, 182, 168, 0.2) 14%, transparent 42%),
        radial-gradient(ellipse at 45% 28%, rgba(190, 184, 170, 0.15) 10%, transparent 35%),
        /* — 球体光照 (高光左上 → 暗部右下) — */
        radial-gradient(circle at 36% 34%,
            rgba(250, 248, 240, 1) 0%,
            rgba(235, 230, 218, 0.92) 14%,
            rgba(215, 210, 198, 0.78) 35%,
            rgba(195, 190, 178, 0.55) 58%,
            rgba(175, 168, 155, 0.25) 80%,
            rgba(150, 143, 130, 0.06) 95%,
            transparent 100%);
    animation: moon-breathe 12s ease-in-out infinite;
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
                box-shadow 0.4s ease,
                scale 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* 表面高亮光斑 — 模拟阳光反射点 */
.core-inner {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    transform: translate(-65%, -65%);
    background: radial-gradient(circle,
        rgba(255, 253, 245, 0.7) 0%,
        rgba(245, 240, 228, 0.3) 40%,
        transparent 100%);
    box-shadow: 0 0 6px rgba(255, 252, 240, 0.4);
    animation: moon-glow 12s ease-in-out infinite;
    transition: scale 0.6s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.6s ease;
}

/* ========================================
   脉冲波纹 — 三层同心扩散 (冷色对比暖月)
   ======================================== */

@keyframes pulse-ring-1 {
    0%   { transform: translate(-50%, -50%) scale(0.4); opacity: 0.09; }
    100% { transform: translate(-50%, -50%) scale(2.4); opacity: 0; }
}
@keyframes pulse-ring-2 {
    0%   { transform: translate(-50%, -50%) scale(0.35); opacity: 0.06; }
    100% { transform: translate(-50%, -50%) scale(3.0); opacity: 0; }
}
@keyframes pulse-ring-3 {
    0%   { transform: translate(-50%, -50%) scale(0.3); opacity: 0.04; }
    100% { transform: translate(-50%, -50%) scale(3.6); opacity: 0; }
}

.core-pulse {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 86px;
    height: 86px;
    border-radius: 50%;
    border: 1.6px solid rgba(200, 195, 180, 0.12);
    transform: translate(-50%, -50%);
    animation: pulse-ring-1 18s ease-out infinite;
    transition: scale 0.6s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.6s ease;
}

.core-pulse::before {
    content: '';
    position: absolute;
    inset: -22px;
    border-radius: 50%;
    border: 1.4px solid rgba(190, 185, 170, 0.06);
    animation: pulse-ring-2 18s ease-out 6s infinite;
    transition: scale 0.6s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.6s ease;
}

.core-pulse::after {
    content: '';
    position: absolute;
    inset: -48px;
    border-radius: 50%;
    border: 1px solid rgba(175, 170, 155, 0.04);
    animation: pulse-ring-3 18s ease-out 12s infinite;
    transition: scale 0.6s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.6s ease;
}

/* ========================================
   Hover — 月光增强 + 波纹加速
   ======================================== */
.constellation:not(.active) .constellation-core:hover .core-dot {
    animation: none;
    transform: translate(-50%, -50%) scale(1.14);
    box-shadow:
        0 0 16px 6px rgba(230, 225, 210, 0.7),
        0 0 55px 14px rgba(210, 205, 190, 0.35),
        0 0 110px 32px rgba(190, 185, 170, 0.15),
        0 0 200px 60px rgba(170, 165, 150, 0.06);
}

.constellation:not(.active) .constellation-core:hover .core-inner {
    box-shadow: 0 0 10px rgba(255, 252, 240, 0.55);
}

.constellation:not(.active) .constellation-core:hover .core-pulse {
    border-color: rgba(210, 205, 190, 0.25);
    animation-duration: 2.5s;
}
.constellation:not(.active) .constellation-core:hover .core-pulse::before {
    animation-duration: 2.5s;
    border-color: rgba(200, 195, 180, 0.14);
}
.constellation:not(.active) .constellation-core:hover .core-pulse::after {
    animation-duration: 2.5s;
    border-color: rgba(190, 185, 170, 0.09);
}

/* ========================================
   激活状态 — 月球缩小、光晕减弱
   ======================================== */
.constellation.active .core-dot {
    scale: 0.45;
    box-shadow:
        0 0 6px 2px rgba(220, 215, 200, 0.35),
        0 0 18px 5px rgba(200, 195, 180, 0.14),
        0 0 36px 10px rgba(180, 175, 160, 0.05),
        0 0 70px 20px rgba(160, 155, 140, 0.02);
}

.constellation.active .core-inner {
    scale: 0.45;
    opacity: 0.5;
}

/* 脉冲波纹等比缩小 */
.constellation.active .core-pulse,
.constellation.active .core-pulse::before,
.constellation.active .core-pulse::after {
    scale: 0.45;
    opacity: 0.4;
}

/* Motto 跟随月球缩放 */
.constellation.active .core-motto {
    scale: 0.55;
    top: calc(100% + 12px);
    opacity: 0.6;
}

/* ========================================
   Motto — 双行排版，呼吸文字
   ======================================== */
@keyframes motto-glow {
    0%, 100% { opacity: 0.55; }
    50%      { opacity: 0.9; }
}

.core-motto {
    position: absolute;
    top: calc(100% + 36px);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    pointer-events: none;
    user-select: none;
    white-space: nowrap;
    animation: motto-glow 3.5s ease-in-out infinite;
    transition: scale 0.6s cubic-bezier(0.34, 1.56, 0.64, 1),
                top 0.6s cubic-bezier(0.34, 1.56, 0.64, 1),
                opacity 0.6s ease;
}

.motto-cn {
    font-family: var(--font-mono);
    font-size: 1.15rem;
    font-weight: 600;
    letter-spacing: 0.24em;
    color: rgba(200, 225, 255, 0.85);
    text-shadow:
        0 0 14px rgba(140, 200, 255, 0.5),
        0 0 40px rgba(100, 160, 255, 0.2),
        0 0 80px rgba(60, 120, 255, 0.1);
}

.motto-en {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(150, 190, 230, 0.55);
    text-shadow: 0 0 10px rgba(120, 180, 255, 0.25);
}

/* 节点容器 */
.constellation-nodes {
    position: absolute;
    inset: 0;
    z-index: 1;
}

/* 单个技能节点 */
.constellation-node {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.45rem 0.85rem;
    border-radius: 9999px;
    background: rgba(10, 10, 20, 0.75);
    border: 1px solid rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    cursor: default;
    white-space: nowrap;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    /* JS 定位：top/left 由 JS 设置，CSS 用 transform 做 translate(-50%, -50%) */ 
    transform: translate(-50%, -50%);
}

.constellation-node:hover {
    background: rgba(20, 20, 40, 0.9);
    border-color: rgba(255, 255, 255, 0.35);
    transform: translate(-50%, -50%) scale(1.15);
    box-shadow:
        0 8px 30px rgba(0, 0, 0, 0.5),
        0 0 40px var(--node-glow, rgba(79, 140, 255, 0.25));
    z-index: 10;
}

/* 未激活状态：所有星子隐藏并聚拢在中心 */
.constellation:not(.active) .constellation-node {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.15);
    pointer-events: none;
}

/* 激活后星子入场过渡 — JS 会给每个节点 staggered transition */
.constellation.active .constellation-node {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
}

/* 节点发光颜色 */
.constellation-node[data-category="lang"]   { --node-glow: rgba(79, 140, 255, 0.3);  }
.constellation-node[data-category="fe"]     { --node-glow: rgba(34, 211, 238, 0.3);  }
.constellation-node[data-category="be"]     { --node-glow: rgba(168, 85, 247, 0.3);  }
.constellation-node[data-category="devops"] { --node-glow: rgba(192, 132, 252, 0.3); }
.constellation-node[data-category="ai"]     { --node-glow: rgba(34, 211, 238, 0.35); }

/* 节点图标 */
.node-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    object-fit: contain;
    filter: drop-shadow(0 0 4px rgba(255, 255, 255, 0.3));
    transition: all 0.35s ease;
}

.node-icon-ai {
    width: 18px;
    height: 18px;
}

.constellation-node:hover .node-icon {
    transform: scale(1.25);
    filter: drop-shadow(0 0 8px var(--node-glow, rgba(79, 140, 255, 0.7)));
}

/* 节点文字 */
.node-label {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--text-secondary);
    letter-spacing: 0.02em;
    transition: color 0.35s ease;
}

.constellation-node:hover .node-label {
    color: var(--text-primary);
}

/* 展开 / 收拢切换提示 — 置于星座容器外，极简隐蔽 */
.constellation-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    margin: 0 auto 0.8rem;
    padding: 0.3rem 0.75rem;
    border-radius: 9999px;
    border: 1px solid rgba(160, 200, 255, 0.08);
    background: transparent;
    cursor: pointer;
    white-space: nowrap;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 400;
    line-height: 1;
    opacity: 0.35;
    transition: all 0.4s ease;
    color: rgba(160, 200, 255, 0.6);
}

.toggle-icon {
    font-size: 0.65rem;
    line-height: 1;
    transition: transform 0.5s ease;
}

.constellation-toggle:hover {
    opacity: 0.75;
    border-color: rgba(180, 220, 255, 0.2);
    background: rgba(160, 200, 255, 0.04);
    color: rgba(200, 230, 255, 0.85);
}

.constellation-toggle:hover .toggle-icon {
    transform: scale(1.2);
}

/* 激活后状态 */
.constellation-toggle.active-state {
    opacity: 0.45;
    border-color: rgba(200, 180, 255, 0.12);
    color: rgba(200, 180, 240, 0.55);
}

.constellation-toggle.active-state .toggle-icon {
    transform: rotate(180deg);
}

.constellation-toggle.active-state:hover {
    opacity: 0.8;
    border-color: rgba(220, 200, 255, 0.25);
    color: rgba(220, 200, 255, 0.9);
}

/* 坍塌动画中隐藏 */
.constellation-toggle.collapsing-state {
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
}


/* ============================================ */
/* tech-stack.css */
/* ============================================ */

/* ============================================================
   TECH-STACK MODULE
   Auto-generated by split-css.js
   ============================================================ */

/* ============================================================
   卡片 03：技术栈 — 三栏分层展示
   ============================================================ */
.tech-columns {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.45rem;
    padding: 0;
    position: relative;
    z-index: 1;
    width: 100%;
    margin-bottom: 0.5rem;
}

.tech-col {
    text-align: center;
    padding: 0.55rem 0.35rem 0.4rem;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
}

.tech-col:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.14);
    transform: translateY(-3px);
}

/* 每栏个性化的 accent 色 */
.tech-col-fe    { --col-accent: var(--accent-blue);   }
.tech-col-be    { --col-accent: var(--accent-purple); }
.tech-col-infra { --col-accent: var(--accent-cyan);   }

.tech-col-label {
    display: block;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--col-accent, var(--text-muted));
    margin-bottom: 0.35rem;
    opacity: 0.75;
    transition: opacity 0.4s ease;
}

.tech-col:hover .tech-col-label {
    opacity: 1;
}

.tech-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.18rem;
}

.tech-list li {
    font-size: 0.68rem;
    font-weight: 500;
    color: var(--text-secondary);
    line-height: 1.35;
    padding: 0.08rem 0;
    transition: color 0.35s ease;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.05rem;
}

.tech-sub {
    display: block;
    font-size: 0.69rem;
    font-weight: 400;
    color: var(--text-muted);
    opacity: 0.5;
    letter-spacing: 0.03em;
    transition: opacity 0.35s ease;
}

.tech-col:hover .tech-list li {
    color: var(--text-primary);
}

.tech-col:hover .tech-sub {
    opacity: 0.7;
}

/* 卡片 hover 时所有栏微亮 */
.tech-card:hover .tech-col {
    border-color: rgba(255, 255, 255, 0.1);
}

/* 技术栈底部总结 */
.tech-summary {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--text-muted);
    text-align: center;
    padding: 0 var(--space-md) var(--space-lg);
    opacity: 0.6;
    letter-spacing: 0.04em;
}


/* ============================================ */
/* explore.css */
/* ============================================ */

/* ============================================================
   EXPLORE MODULE
   Auto-generated by split-css.js
   ============================================================ */

/* ============================================================
   卡片 02：探索方向 — 方向标签 Chips
   ============================================================ */
/* 描述文字为 chips 让路 */
.explore-card .card-desc,
.tech-card .card-desc,
.create-card .card-desc {
    padding-bottom: var(--space-sm);
}

.explore-chips {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.55rem;
    padding: 0 0 var(--space-sm);
    position: relative;
    z-index: 1;
    width: 100%;
}

.explore-chip {
    display: inline-flex;
    align-items: center;
    padding: 0.35rem 0.85rem;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    border-radius: 9999px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.03);
    color: var(--text-secondary);
    cursor: default;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    overflow: hidden;
}

/* 各 chip 的个性化底色 */
.chip-llm  { --chip-glow: rgba(79, 140, 255, 0.3);  --chip-bg: rgba(79, 140, 255, 0.08);  }
.chip-agent { --chip-glow: rgba(168, 85, 247, 0.3);  --chip-bg: rgba(168, 85, 247, 0.08);  }
.chip-edge { --chip-glow: rgba(34, 211, 238, 0.3);   --chip-bg: rgba(34, 211, 238, 0.08);   }

.explore-chip::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 9999px;
    background: var(--chip-bg);
    opacity: 0;
    transition: opacity 0.4s ease;
}

.explore-chip:hover {
    color: var(--text-primary);
    border-color: var(--chip-glow);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px -6px var(--chip-glow);
}

.explore-chip:hover::before {
    opacity: 1;
}

/* 卡片 hover 时所有 chip 微微亮起 */
.explore-card:hover .explore-chip {
    border-color: rgba(255, 255, 255, 0.18);
}

/* chip 下方补充描述 */
.explore-extra {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    line-height: 1.7;
    color: var(--text-muted);
    text-align: center;
    padding: 0 0 var(--space-sm);
    opacity: 0.7;
}




/* ============================================================
   卡片 04：创造与分享 — 项目子卡片 + 补充文案
   ============================================================ */
/* -------- 创造与分享：chips 标签 -------- */
.create-chips {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.55rem;
    padding: 0 0 var(--space-sm);
    margin-bottom: 0.2rem;
}

/* 创造卡片 chip 专属配色 — 暖金调 */
.chip-create {
    --chip-glow: rgba(250, 204, 21, 0.35);
    --chip-bg: rgba(250, 204, 21, 0.08);
}

/* 创造卡片补充描述 */
.create-extra {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    line-height: 1.65;
    color: var(--text-muted);
    text-align: center;
    padding: 0 0 var(--space-sm);
    opacity: 0.65;
}

/* 卡片 hover 火箭火焰加强 */
.create-card:hover .flame-outer {
    opacity: 0.55 !important;
}

.create-card:hover .flame-inner {
    opacity: 0.4 !important;
}

/* ===== 响应式：小屏回退 ===== */
@media (max-width: 680px) {
    .about-grid {
        grid-template-columns: 1fr;
        gap: var(--space-xl);
        max-width: 420px;
    }

    .about-grid-sub {
        grid-template-columns: 1fr;
        gap: var(--space-xl);
    }

    .hero-slide {
        flex-direction: column;
        gap: var(--space-md);
        min-height: auto;
    }

    .hero-slide-text {
        flex: none;
        width: 100%;
        align-items: center;
        text-align: center;
    }

    .hero-slide-image {
        flex: none;
        width: 100%;
        max-width: 260px;
        margin: 0 auto;
        aspect-ratio: 1 / 1;
    }

    .about-card-hero {
        padding: var(--space-md) var(--space-sm) !important;
    }

    .about-card-hero .card-number {
        font-size: 5rem;
        top: -1.2rem;
        right: 0.5rem;
    }

    .hero-header-row {
        flex-direction: column;
        gap: 0.5rem;
    }

    .hero-title-block {
        align-items: center;
    }

    .hero-eyebrow {
        text-align: center;
    }

    .card-title {
        text-align: center;
    }

    .card-title::after {
        margin: 0.4rem auto 0;
    }

    .hero-desc {
        text-align: center;
        align-items: center;
    }

    .about-hero-details {
        align-items: stretch;
    }

    .hero-detail-item {
        justify-content: flex-start;
        padding: 0.55rem 0.7rem;
    }

    .detail-tag {
        margin-left: auto;
    }

    .hero-detail-item:hover {
        transform: none;
    }

    .about-card {
        animation: none !important;
    }

    .about-card:hover {
        animation: none;
        transform: translateY(-6px) scale(1.02);
    }

    .card-illustration {
        width: 90px;
        height: 90px;
        padding: 1.2rem 0 0 0;
        animation: none;
    }

    /* 侧边指示器小屏适配 */
    .carousel-side-indicator {
        right: 2px;
        gap: 8px;
    }
    .carousel-side-dot {
        width: 2px;
        height: 16px;
    }
    .carousel-side-dot.active {
        height: 28px;
    }

    .about-card:hover .card-illustration {
        transform: scale(1.08);
    }

    .card-title {
        padding: var(--space-sm) var(--space-md) 0;
    }

    .card-title::after {
        margin: 0.35rem auto 0;
    }

    .card-desc {
        padding: var(--space-sm) var(--space-md) var(--space-md);
    }

    .card-number {
        font-size: 3.5rem;
        right: 0.5rem;
        top: -0.5rem;
    }

    /* 探索方向 chips 小屏适配 */
    .explore-chips {
        gap: 0.4rem;
        padding: 0 0 0.4rem;
        margin-bottom: 0;
    }
    .explore-chip {
        font-size: 0.7rem;
        padding: 0.3rem 0.7rem;
    }
    .explore-extra {
        font-size: 0.68rem;
        padding: 0 0 0.4rem;
    }
    .card-motto {
        font-size: 0.72rem;
    }

    /* 技术栈三栏小屏适配 */
    .tech-columns {
        gap: 0.4rem;
        padding: 0;
        margin-bottom: 0.4rem;
    }
    .tech-col {
        padding: 0.45rem 0.2rem 0.35rem;
    }
    .tech-col-label {
        font-size: 0.58rem;
    }
    .tech-list li {
        font-size: 0.64rem;
    }
    .tech-sub {
        font-size: 0.62rem;
    }
    .tech-summary {
        font-size: 0.6rem;
        padding: 0 var(--space-sm) var(--space-md);
    }

    /* 创造与分享小屏适配 */
    .create-chips {
        gap: 0.4rem;
        padding: 0 0 0.4rem;
    }
    .create-extra {
        font-size: 0.68rem;
        padding: 0 0 0.4rem;
    }
}


/* ============================================ */
/* modal.css */
/* ============================================ */

/* ============================================================
   技术栈详情弹窗 — 玻璃拟态风格
   ============================================================ */
.tech-modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(10, 10, 20, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.4s ease, visibility 0.4s ease;
}

.tech-modal-overlay.active {
    opacity: 1;
    visibility: visible;
}

.tech-modal {
    background: linear-gradient(135deg,
        rgba(15, 15, 35, 0.95) 0%,
        rgba(20, 20, 45, 0.98) 100%);
    border: 1px solid rgba(79, 140, 255, 0.2);
    border-radius: 20px;
    max-width: 640px;
    width: 90%;
    max-height: 80vh;
    overflow-y: auto;
    padding: 2.5rem;
    position: relative;
    transform: translateY(30px) scale(0.95);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                opacity 0.4s ease;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5),
                0 0 40px rgba(79, 140, 255, 0.1);
}

.tech-modal-overlay.active .tech-modal {
    transform: translateY(0) scale(1);
}

/* 自定义滚动条 */
.tech-modal::-webkit-scrollbar {
    width: 6px;
}

.tech-modal::-webkit-scrollbar-track {
    background: rgba(255, 255, 255, 0.02);
    border-radius: 3px;
}

.tech-modal::-webkit-scrollbar-thumb {
    background: rgba(79, 140, 255, 0.3);
    border-radius: 3px;
}

.tech-modal::-webkit-scrollbar-thumb:hover {
    background: rgba(79, 140, 255, 0.5);
}

.tech-modal-close {
    position: absolute;
    top: 1.2rem;
    right: 1.2rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--text-secondary);
    font-size: 1.2rem;
    cursor: pointer;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    transition: all 0.3s ease;
    z-index: 10;
}

.tech-modal-close:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(79, 140, 255, 0.4);
    color: var(--text-primary);
    transform: rotate(90deg);
}

.tech-modal-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}

.tech-modal-title {
    font-size: 1.75rem;
    font-weight: 800;
    background: linear-gradient(135deg, var(--accent-blue), var(--accent-purple), var(--accent-cyan));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.6rem;
    letter-spacing: -0.02em;
}

.tech-modal-subtitle {
    color: var(--text-muted);
    font-size: 0.95rem;
    font-weight: 400;
    letter-spacing: 0.02em;
}

.tech-modal-body {
    display: flex;
    flex-direction: column;
    gap: 1.8rem;
}

/* 图标区域 - 使用渐变背景 */
.tech-modal-icon-wrapper {
    width: 80px;
    height: 80px;
    margin: 0 auto 1.5rem;
    border-radius: 20px;
    background: linear-gradient(135deg,
        rgba(79, 140, 255, 0.15) 0%,
        rgba(168, 85, 247, 0.15) 100%);
    border: 1px solid rgba(79, 140, 255, 0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
}

.tech-modal-icon-wrapper::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(79, 140, 255, 0.1) 0%, transparent 70%);
    animation: icon-glow 3s ease-in-out infinite;
}

@keyframes icon-glow {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(10%, 10%); }
}

.tech-modal-icon {
    font-size: 2.5rem;
    position: relative;
    z-index: 1;
}

.tech-modal-details {
    color: var(--text-secondary);
    line-height: 1.9;
    font-size: 0.95rem;
}

.tech-modal-details h4 {
    color: var(--text-primary);
    margin: 1.5rem 0 0.8rem;
    font-size: 1.1rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.tech-modal-details h4::before {
    content: '';
    width: 3px;
    height: 1.2em;
    background: linear-gradient(180deg, var(--accent-blue), var(--accent-purple));
    border-radius: 2px;
    display: inline-block;
}

.tech-modal-details ul {
    list-style: none;
    padding: 0;
    margin: 0.8rem 0;
}

.tech-modal-details li {
    padding: 0.7rem 0.8rem;
    margin: 0.4rem 0;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.04);
    transition: all 0.3s ease;
    position: relative;
    padding-left: 2rem;
}

.tech-modal-details li::before {
    content: '▸';
    position: absolute;
    left: 0.8rem;
    color: var(--accent-blue);
    font-weight: bold;
}

.tech-modal-details li:hover {
    background: rgba(79, 140, 255, 0.05);
    border-color: rgba(79, 140, 255, 0.15);
    transform: translateX(5px);
}

.tech-modal-details p {
    margin: 1rem 0;
    padding: 1rem;
    background: rgba(79, 140, 255, 0.03);
    border-left: 3px solid var(--accent-blue);
    border-radius: 0 8px 8px 0;
    font-style: italic;
    color: var(--text-muted);
}

/* 标签样式 */
.tech-tag {
    display: inline-block;
    padding: 0.3rem 0.8rem;
    margin: 0.2rem;
    font-size: 0.8rem;
    border-radius: 9999px;
    background: rgba(79, 140, 255, 0.08);
    border: 1px solid rgba(79, 140, 255, 0.2);
    color: var(--accent-blue);
}

/* 移动端优化 */
@media (max-width: 768px) {
    .tech-modal {
        width: 92%;
        padding: 1.8rem;
        max-height: 85vh;
        border-radius: 16px;
    }

    .tech-modal-title {
        font-size: 1.4rem;
    }

    .tech-modal-icon-wrapper {
        width: 60px;
        height: 60px;
        border-radius: 16px;
    }

    .tech-modal-icon {
        font-size: 2rem;
    }
}


/* ============================================ */
/* animations.css */
/* ============================================ */

/* ============================================================
   ANIMATIONS MODULE
   Auto-generated by split-css.js
   ============================================================ */

/* ============================================================
   REVEAL ANIMATION (滚动渐显) — C3 优化节奏
   ============================================================ */
.reveal {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.85s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.85s cubic-bezier(0.16, 1, 0.3, 1);
}

.reveal.visible {
    opacity: 1;
    transform: translateY(0);
}

/* C3: section 标题特殊入场 — 更优雅的淡入 */
.section .section-label,
.section .card-title,
.section .stat-label,
.section .contact-subtitle {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.1s,
                transform 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.1s;
}
.section.reveal-done .section-label,
.section.reveal-done .card-title,
.section.reveal-done .stat-label,
.section.reveal-done .contact-subtitle {
    opacity: 1;
    transform: translateY(0);
}

/* 入场顺序延迟 */
.hero-content .reveal:nth-child(1) { transition-delay: 0.15s; }
.hero-content .reveal:nth-child(2) { transition-delay: 0.3s; }
.hero-content .reveal:nth-child(3) { transition-delay: 0.45s; }
.hero-content .reveal:nth-child(4) { transition-delay: 0.6s; }
.hero-content .reveal:nth-child(5) { transition-delay: 0.75s; }

/* 非 hero 区域的 reveal 交错延迟 */
.section-inner .reveal:nth-child(2) { transition-delay: 0.08s; }
.section-inner .reveal:nth-child(3) { transition-delay: 0.16s; }
.section-inner .reveal:nth-child(4) { transition-delay: 0.24s; }
.section-inner .reveal:nth-child(5) { transition-delay: 0.32s; }
.section-inner .reveal:nth-child(6) { transition-delay: 0.40s; }
.section-inner .reveal:nth-child(7) { transition-delay: 0.48s; }
.section-inner .reveal:nth-child(8) { transition-delay: 0.56s; }


/* ============================================ */
/* responsive.css */
/* ============================================ */

/* ============================================================
   RESPONSIVE MODULE
   Auto-generated by split-css.js
   ============================================================ */

/* ============================================================
   RESPONSIVE
   ============================================================ */
@media (max-width: 768px) {
    .section {
        padding: 5rem 1rem 4rem;
    }

    .section + .section::before {
        left: 8%;
        right: 8%;
    }

    .section + .section::after {
        top: -3.5px;
        width: 6px;
        height: 6px;
    }

    .hero-orbits {
        width: 280px;
        height: 280px;
    }

    .orbit-ring.ring-2 { inset: 20px; }
    .orbit-ring.ring-3 { inset: 40px; }

    .grid-overlay {
        background-size: 40px 40px;
    }

    .marquee-section {
        padding: 1.5rem 0;
        margin: 1rem 0 1.5rem;
    }

    .marquee-content span {
        font-size: 1.15rem;
        letter-spacing: 0.08em;
        filter: drop-shadow(0 0 4px rgba(79, 140, 255, 0.25));
    }

    .footer-motto {
        font-size: 0.82rem;
        letter-spacing: 0.08em;
    }

    .marquee-content {
        gap: 1rem;
    }

    .marquee-track {
        animation-duration: 25s;
        gap: 1.5rem;
    }

    .about-grid {
        grid-template-columns: 1fr;
        max-width: 420px;
    }

    .constellation {
        max-height: 520px;
    }

    .constellation-node {
        padding: 0.38rem 0.7rem;
    }

    .core-motto {
        font-size: 0.66rem;
        margin-top: 10px;
    }

    .node-label {
        font-size: 0.72rem;
    }

    .core-dot {
        width: 16px;
        height: 16px;
    }

    .contact-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: var(--space-md);
    }

    .contact-card:nth-child(odd),
    .contact-card:nth-child(even) {
        transform: none;
    }

    .avatar {
        width: 100px;
        height: 100px;
    }

    .avatar-status {
        width: 13px;
        height: 13px;
        bottom: 2px;
        right: 2px;
    }

    .social-links {
        gap: var(--space-xs);
    }

    .social-link {
        padding: 0.4rem 1rem;
        font-size: 0.8rem;
    }

    .hero-bio {
        padding: var(--space-sm) var(--space-md);
    }

    .skill-chip-tag {
        font-size: 0.7rem;
        padding: 0.2rem 0.55rem;
    }

    .hero-desc {
        font-size: 0.82rem;
    }

    #spotlight {
        width: 400px;
        height: 400px;
    }

    /* ---- 移动端导航 ---- */
    .site-nav {
        height: 52px;
    }
    .nav-inner {
        padding: 0 var(--space-md);
    }
    .nav-logo {
        font-size: 0.95rem;
        gap: 0.45rem;
    }
    .nav-logo svg {
        width: 24px;
        height: 24px;
    }
    .nav-toggle {
        display: flex;
    }
    .nav-links {
        position: fixed;
        top: 0;
        right: 0;
        width: 260px;
        height: 100vh;
        flex-direction: column;
        gap: 0;
        padding: 80px var(--space-lg) var(--space-lg);
        background: rgba(10, 10, 20, 0.94);
        backdrop-filter: blur(20px) saturate(180%);
        -webkit-backdrop-filter: blur(20px) saturate(180%);
        border-left: 1px solid rgba(255, 255, 255, 0.08);
        transform: translateX(100%);
        transition: transform 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
        box-shadow: -8px 0 40px rgba(0, 0, 0, 0.6);
    }
    .nav-links.open {
        transform: translateX(0);
    }
    .nav-link {
        padding: 0.75rem 1rem;
        font-size: 0.95rem;
        border-radius: 10px;
    }
    /* 移动端隐藏指示器 */
    .nav-indicator {
        display: none;
    }
}

@media (max-width: 480px) {
    .contact-grid {
        grid-template-columns: 1fr 1fr;
    }

    .constellation {
        max-height: 420px;
    }

    .constellation-node {
        padding: 0.32rem 0.6rem;
    }

    .core-motto {
        font-size: 0.6rem;
        margin-top: 8px;
        letter-spacing: 0.08em;
    }

    .node-label {
        font-size: 0.68rem;
    }

    .node-icon {
        width: 14px;
        height: 14px;
    }
    .node-icon-ai {
        width: 16px;
        height: 16px;
    }

    .core-dot {
        width: 14px;
        height: 14px;
    }
}

